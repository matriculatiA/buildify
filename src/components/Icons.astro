---
// Централен файл с всички SVG икони
// Употреба: <Icon name="web" size={24} />
interface Props {
  name: string;
  size?: number;
  class?: string;
}
const { name, size = 24, class: cls = '' } = Astro.props;
---

{name === 'web' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={cls}>
    <rect x="2" y="3" width="20" height="16" rx="1" fill="#111"/>
    <rect x="5" y="6" width="14" height="7" fill="#f5e642"/>
    <rect x="5" y="15" width="4" height="1.5" fill="#f5e642"/>
    <rect x="10" y="15" width="4" height="1.5" fill="#f5e642"/>
    <rect x="9" y="19" width="6" height="1.5" fill="#111"/>
    <rect x="7" y="19" width="10" height="1" fill="#111"/>
  </svg>
)}

{name === 'bot' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={cls}>
    <rect x="4" y="8" width="16" height="12" rx="1" fill="#111"/>
    <rect x="8" y="11" width="3" height="3" fill="#f5e642"/>
    <rect x="13" y="11" width="3" height="3" fill="#f5e642"/>
    <rect x="9" y="16" width="6" height="1.5" fill="#f5e642"/>
    <rect x="11" y="4" width="2" height="4" fill="#111"/>
    <circle cx="12" cy="3.5" r="1.5" fill="#111"/>
    <rect x="2" y="11" width="2" height="4" rx="1" fill="#111"/>
    <rect x="20" y="11" width="2" height="4" rx="1" fill="#111"/>
  </svg>
)}

{name === 'qa' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={cls}>
    <rect x="3" y="3" width="18" height="14" rx="1" fill="#111"/>
    <path d="M8 7 L11 11 L16 6" stroke="#f5e642" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    <rect x="7" y="19" width="10" height="2" fill="#111"/>
    <rect x="11" y="17" width="2" height="2" fill="#111"/>
  </svg>
)}

{name === 'plugin' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={cls}>
    <rect x="3" y="10" width="11" height="11" rx="1" fill="#111"/>
    <rect x="6" y="6" width="5" height="4" fill="#111"/>
    <rect x="13" y="6" width="5" height="4" fill="#111"/>
    <rect x="14" y="10" width="7" height="7" rx="1" fill="#f5e642"/>
    <rect x="17" y="3" width="2" height="3" fill="#111"/>
    <rect x="21" y="10" width="2" height="4" fill="#111"/>
  </svg>
)}

{name === 'form-broken' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={cls}>
    <rect x="3" y="3" width="18" height="18" rx="1" fill="#111"/>
    <rect x="6" y="7" width="8" height="1.5" fill="#f5e642"/>
    <rect x="6" y="11" width="12" height="1.5" fill="#f5e642"/>
    <rect x="6" y="15" width="5" height="1.5" fill="#f5e642"/>
    <path d="M17 13 L20 16 M20 13 L17 16" stroke="#f5e642" stroke-width="2" stroke-linecap="round"/>
  </svg>
)}

{name === 'speed' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={cls}>
    <path d="M12 3 A9 9 0 0 1 21 12 A9 9 0 0 1 3 12 A9 9 0 0 1 12 3Z" fill="#111"/>
    <path d="M6 12 A6 6 0 0 1 18 12" fill="#f5e642"/>
    <line x1="12" y1="12" x2="16" y2="7" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
    <circle cx="12" cy="12" r="1.5" fill="white"/>
  </svg>
)}

{name === 'mobile-broken' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={cls}>
    <rect x="5" y="2" width="14" height="20" rx="2" fill="#111"/>
    <rect x="7" y="4" width="10" height="13" fill="#f5e642"/>
    <rect x="10" y="19" width="4" height="1.5" fill="#f5e642"/>
    <path d="M10 8 L14 12 M14 8 L10 12" stroke="#111" stroke-width="1.5" stroke-linecap="round"/>
  </svg>
)}

{name === 'link-broken' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={cls}>
    <path d="M9 7 L6 7 A5 5 0 0 0 6 17 L9 17" stroke="#111" stroke-width="3" stroke-linecap="round" fill="none"/>
    <path d="M15 7 L18 7 A5 5 0 0 1 18 17 L15 17" stroke="#111" stroke-width="3" stroke-linecap="round" fill="none"/>
    <line x1="9" y1="12" x2="11" y2="12" stroke="#f5e642" stroke-width="2.5" stroke-linecap="round"/>
    <line x1="13" y1="12" x2="15" y2="12" stroke="#f5e642" stroke-width="2.5" stroke-linecap="round"/>
    <line x1="12" y1="4" x2="12" y2="6" stroke="#111" stroke-width="2" stroke-linecap="round"/>
    <line x1="12" y1="18" x2="12" y2="20" stroke="#111" stroke-width="2" stroke-linecap="round"/>
  </svg>
)}

{name === 'check' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={cls}>
    <rect x="2" y="2" width="20" height="20" fill="#111"/>
    <path d="M6 12 L10 16 L18 8" stroke="#f5e642" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
  </svg>
)}

{name === 'arrow-right' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={cls}>
    <rect x="2" y="2" width="20" height="20" fill="#111"/>
    <path d="M8 12 L16 12 M13 8 L17 12 L13 16" stroke="#f5e642" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
  </svg>
)}

{name === 'clock' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={cls}>
    <circle cx="12" cy="12" r="10" fill="#111"/>
    <circle cx="12" cy="12" r="7" fill="#f5e642"/>
    <line x1="12" y1="8" x2="12" y2="12" stroke="#111" stroke-width="2" stroke-linecap="round"/>
    <line x1="12" y1="12" x2="15" y2="14" stroke="#111" stroke-width="2" stroke-linecap="round"/>
    <circle cx="12" cy="12" r="1" fill="#111"/>
  </svg>
)}

{name === 'no-fee' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={cls}>
    <rect x="2" y="6" width="20" height="13" rx="1" fill="#111"/>
    <rect x="2" y="9" width="20" height="4" fill="#f5e642"/>
    <rect x="5" y="14" width="4" height="2" fill="#f5e642"/>
    <path d="M18 6 L20 4 M4 4 L18 18" stroke="#111" stroke-width="2.5" stroke-linecap="round"/>
    <path d="M4 4 L20 4 L20 18" stroke="#f5e642" stroke-width="2" stroke-linecap="round" fill="none"/>
  </svg>
)}

{name === 'location' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={cls}>
    <path d="M12 2 A7 7 0 0 1 19 9 C19 14 12 22 12 22 C12 22 5 14 5 9 A7 7 0 0 1 12 2Z" fill="#111"/>
    <circle cx="12" cy="9" r="3" fill="#f5e642"/>
  </svg>
)}

{name === 'seo' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={cls}>
    <circle cx="10" cy="10" r="8" fill="#111"/>
    <circle cx="10" cy="10" r="5" fill="#f5e642"/>
    <circle cx="10" cy="10" r="2" fill="#111"/>
    <line x1="16" y1="16" x2="22" y2="22" stroke="#111" stroke-width="3" stroke-linecap="round"/>
  </svg>
)}

{name === 'star' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={cls}>
    <polygon points="12,2 15,9 22,9 17,14 19,21 12,17 5,21 7,14 2,9 9,9" fill="#111"/>
    <polygon points="12,5 14,10 19,10 15,13 17,18 12,15 7,18 9,13 5,10 10,10" fill="#f5e642"/>
  </svg>
)}
