---
const navLinks = [
  { href: '/uebsajtove', label: 'Уебсайтове' },
  { href: '/ai-botove',  label: 'AI Ботове' },
  { href: '/qa',         label: 'QA Тестване' },
  { href: '/plugini',    label: 'Плъгини' },
  { href: '/blog',       label: 'Блог' },
];

const current = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50 bg-brand-bg/90 backdrop-blur-sm border-b border-brand-border">
  <nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">

    <!-- Logo -->
    <a href="/" class="font-display font-800 text-xl tracking-tight text-brand-ink hover:text-brand-green transition-colors">
      buildify<span class="text-brand-green">.</span>bg
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex items-center gap-8">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class={`text-sm font-medium transition-colors hover:text-brand-green ${
              current.startsWith(link.href)
                ? 'text-brand-green'
                : 'text-brand-muted'
            }`}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- CTA -->
    <a
      href="/kontakt"
      class="hidden md:inline-flex items-center gap-2 bg-brand-green text-white text-sm font-medium px-5 py-2.5 rounded-full hover:bg-brand-dark transition-colors"
    >
      Безплатна консултация
      <span aria-hidden="true">→</span>
    </a>

    <!-- Mobile hamburger -->
    <button id="menu-toggle" class="md:hidden p-2 text-brand-ink" aria-label="Меню">
      <svg width="22" height="16" viewBox="0 0 22 16" fill="none">
        <line x1="0" y1="1"  x2="22" y2="1"  stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="0" y1="8"  x2="22" y2="8"  stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="0" y1="15" x2="22" y2="15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-brand-border bg-brand-bg">
    <ul class="px-6 py-4 flex flex-col gap-4">
      {navLinks.map(link => (
        <li>
          <a href={link.href} class="text-sm font-medium text-brand-muted hover:text-brand-green transition-colors block py-1">
            {link.label}
          </a>
        </li>
      ))}
      <li>
        <a href="/kontakt" class="inline-flex items-center gap-2 bg-brand-green text-white text-sm font-medium px-5 py-2.5 rounded-full mt-2">
          Безплатна консултация →
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu   = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
