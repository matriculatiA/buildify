<script>
  // --- Typewriter effect ---
  const phrases = [
    'Правна защита,\nна която можете\nда разчитате.',
    'Вашите права —\nнашият приоритет.',
    'Опит. Стратегия.\nРезултат.',
  ];
  let phraseIdx = 0, charIdx = 0, deleting = false;
  const el = document.getElementById('typewriter-text');
  function type() {
    if (!el) return;
    const current = phrases[phraseIdx];
    if (!deleting) {
      el.innerHTML = current.slice(0, charIdx + 1).replace(/\n/g, '<br/>');
      charIdx++;
      if (charIdx === current.length) { deleting = true; setTimeout(type, 2400); return; }
    } else {
      el.innerHTML = current.slice(0, charIdx - 1).replace(/\n/g, '<br/>');
      charIdx--;
      if (charIdx === 0) { deleting = false; phraseIdx = (phraseIdx + 1) % phrases.length; }
    }
    setTimeout(type, deleting ? 40 : 60);
  }
  type();

  // --- Scroll reveal ---
  const allReveal = document.querySelectorAll('.reveal, .reveal-left, .reveal-right');
  const revealIO = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) { e.target.classList.add('visible'); revealIO.unobserve(e.target); }
    });
  }, { threshold: 0.1 });
  allReveal.forEach(r => revealIO.observe(r));

  // --- Nav scroll + progress bar ---
  const nav = document.getElementById('law-nav');
  const progress = document.getElementById('scroll-progress');
  window.addEventListener('scroll', () => {
    const y = window.scrollY;
    if (nav) nav.style.boxShadow = y > 60 ? '0 4px 30px rgba(0,0,0,.5)' : 'none';
    if (progress) {
      const total = document.body.scrollHeight - window.innerHeight;
      progress.style.width = (total > 0 ? (y / total) * 100 : 0) + '%';
    }
  }, { passive: true });
</script>
