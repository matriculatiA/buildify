---
import DemoLayout from '../../layouts/DemoLayout.astro';
---
<DemoLayout title="Адвокатска Кантора Петров и Партньори — Бургас" accent="#c9a84c">
<style>
  :root { --navy: #0f1e35; --gold: #c9a84c; --light-gold: #f5e9c8; --cream: #faf8f4; --text: #1e293b; }
  * { box-sizing: border-box; }
  a { text-decoration: none; }
  section { padding: 80px 24px; }
  .container { max-width: 1100px; margin: 0 auto; }
  .tag { font-size: 10px; font-weight: 700; letter-spacing: .2em; text-transform: uppercase; color: var(--gold); margin-bottom: 16px; display: block; }

  /* Scroll reveal */
  .reveal { opacity: 0; transform: translateY(32px); transition: opacity .7s ease, transform .7s ease; }
  .reveal.visible { opacity: 1; transform: translateY(0); }
  .reveal-left { opacity: 0; transform: translateX(-48px); transition: opacity .8s ease, transform .8s ease; }
  .reveal-left.visible { opacity: 1; transform: translateX(0); }
  .reveal-right { opacity: 0; transform: translateX(48px); transition: opacity .8s ease, transform .8s ease; }
  .reveal-right.visible { opacity: 1; transform: translateX(0); }

  /* Buttons */
  .btn { background: var(--gold); color: #0f1e35; font-weight: 700; padding: 14px 32px; display: inline-block; font-size: 13px; letter-spacing: .08em; text-transform: uppercase; transition: all .2s; border: none; cursor: pointer; }
  .btn:hover { background: #b8943a; transform: translateY(-2px); box-shadow: 0 8px 24px rgba(201,168,76,.4); }
  .btn-ghost { border: 2px solid rgba(255,255,255,.3); color: white; font-weight: 700; padding: 12px 28px; display: inline-block; font-size: 13px; letter-spacing: .08em; text-transform: uppercase; transition: all .2s; }
  .btn-ghost:hover { border-color: var(--gold); color: var(--gold); }

  /* Typewriter */
  #typewriter-text { border-right: 3px solid var(--gold); padding-right: 4px; }
  @keyframes blink { 0%,100% { border-color: var(--gold); } 50% { border-color: transparent; } }
  #typewriter-text { animation: blink .8s step-end infinite; }

  /* Practice area cards - 3D flip */
  .flip-card { perspective: 1000px; height: 260px; cursor: pointer; }
  .flip-inner { position: relative; width: 100%; height: 100%; transform-style: preserve-3d; transition: transform .6s cubic-bezier(.25,.46,.45,.94); }
  .flip-card:hover .flip-inner { transform: rotateY(180deg); }
  .flip-front, .flip-back { position: absolute; inset: 0; backface-visibility: hidden; -webkit-backface-visibility: hidden; padding: 32px; }
  .flip-front { background: white; border: 1px solid #e2d9c4; }
  .flip-back { background: var(--navy); border: 1px solid rgba(201,168,76,.3); transform: rotateY(180deg); }

  /* Timeline */
  .timeline-item { display: flex; gap: 32px; padding: 32px 0; position: relative; }
  .timeline-item:not(:last-child)::after { content: ''; position: absolute; left: 24px; top: 80px; bottom: -24px; width: 2px; background: linear-gradient(to bottom, var(--gold), rgba(201,168,76,.1)); }
  .timeline-dot { width: 48px; height: 48px; background: var(--navy); border: 2px solid var(--gold); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--gold); font-weight: 900; font-size: 14px; flex-shrink: 0; font-family: monospace; transition: background .3s, transform .3s; position: relative; z-index: 1; }
  .timeline-item:hover .timeline-dot { background: var(--gold); color: var(--navy); transform: scale(1.2); }
  .timeline-content { padding-top: 8px; transition: transform .3s; }
  .timeline-item:hover .timeline-content { transform: translateX(8px); }

  /* Marquee ticker */
  @keyframes marquee { from { transform: translateX(0); } to { transform: translateX(-50%); } }
  .marquee-track { display: flex; gap: 0; animation: marquee 30s linear infinite; width: max-content; }
  .marquee-track:hover { animation-play-state: paused; }
  .ticker-item { padding: 0 48px; border-right: 1px solid rgba(255,255,255,.1); white-space: nowrap; }

  /* Team cards */
  .team-card { border: 1px solid rgba(201,168,76,.2); padding: 28px; position: relative; overflow: hidden; transition: border-color .3s, transform .3s; }
  .team-card::after { content: ''; position: absolute; inset: 0; background: linear-gradient(135deg, rgba(201,168,76,.06), transparent); opacity: 0; transition: opacity .3s; }
  .team-card:hover { border-color: rgba(201,168,76,.6); transform: translateY(-4px); }
  .team-card:hover::after { opacity: 1; }

  /* Animated stat numbers */
  .stat-num { font-size: 2.8rem; font-weight: 900; color: var(--gold); line-height: 1; display: block; }

  /* Nav scroll */
  #law-nav { transition: background .3s; }
</style>

<!-- NAV -->
<div id="scroll-progress" style="position:fixed;top:32px;left:0;height:3px;background:var(--gold);width:0%;z-index:200;transition:width .1s linear;pointer-events:none"></div>
<nav id="law-nav" style="background:var(--navy);padding:0 40px;display:flex;align-items:center;justify-content:space-between;height:76px;position:sticky;top:32px;z-index:100;border-bottom:1px solid rgba(201,168,76,.15)">
  <div>
    <div style="color:white;font-size:16px;font-weight:800;letter-spacing:.04em;line-height:1;font-family:'Playfair Display',serif">ПЕТРОВ И ПАРТНЬОРИ</div>
    <div style="color:var(--gold);font-size:10px;letter-spacing:.2em;text-transform:uppercase;margin-top:4px">Адвокатска кантора · Бургас</div>
  </div>
  <div style="display:flex;gap:32px;align-items:center">
    {['Практики', 'Екип', 'За нас', 'Контакти'].map(l => (
      <a href="#" style="color:rgba(255,255,255,.5);font-size:13px;font-weight:500;letter-spacing:.04em;display:none;transition:color .2s" class="nav-link" onmouseover="this.style.color='var(--gold)'" onmouseout="this.style.color='rgba(255,255,255,.5)'">{l}</a>
    ))}
    <a href="#konsultaciq" class="btn" style="padding:10px 20px;font-size:12px">Безплатна консултация</a>
  </div>
</nav>
<style>@media(min-width:768px){.nav-link{display:block!important}}</style>

<!-- HERO with typewriter -->
<div style="background-color:#0f1e35;padding:100px 24px 80px;position:relative;overflow:hidden;min-height:92vh;display:flex;align-items:center">
  <img src="/images/advokat-hero.jpg" alt="" fetchpriority="high" loading="eager" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center;z-index:0;display:block"/>
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(15,30,53,.93) 0%,rgba(15,30,53,.86) 60%,rgba(15,30,53,.80) 100%);pointer-events:none;z-index:1"></div>
  <!-- Background decorations -->
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(201,168,76,.03) 1px,transparent 1px),linear-gradient(90deg,rgba(201,168,76,.03) 1px,transparent 1px);background-size:60px 60px;pointer-events:none"></div>
  <div style="position:absolute;right:-200px;top:50%;transform:translateY(-50%);width:700px;height:700px;border-radius:50%;background:radial-gradient(circle,rgba(201,168,76,.06) 0%,transparent 65%);pointer-events:none"></div>

  <div class="container" style="position:relative;z-index:2;max-width:860px">
    <div class="reveal" style="display:flex;align-items:center;gap:12px;margin-bottom:36px">
      <div style="height:1px;width:48px;background:var(--gold)"></div>
      <span style="color:var(--gold);font-size:11px;font-weight:700;letter-spacing:.2em;text-transform:uppercase">Основана 1998 · Бургас · Член на Адвокатска колегия</span>
    </div>

    <h1 class="reveal" style="color:white;font-size:clamp(2.2rem,5.5vw,4.2rem);font-weight:900;line-height:1.06;margin-bottom:28px;letter-spacing:-.02em;font-family:'Playfair Display',serif">
      <span id="typewriter-text"></span>
    </h1>

    <p class="reveal" style="color:rgba(255,255,255,.5);font-size:18px;line-height:1.8;max-width:580px;margin-bottom:48px">
      25 години опит в гражданско, търговско и трудово право. Повече от 2000 успешно приключени дела. Работим с физически лица и фирми.
    </p>

    <div class="reveal" style="display:flex;gap:16px;flex-wrap:wrap;margin-bottom:72px">
      <a href="#konsultaciq" class="btn">Безплатна консултация →</a>
      <a href="#praktiki" class="btn-ghost">Нашите практики</a>
    </div>

    <!-- Animated stats -->
    <div class="reveal" style="display:grid;grid-template-columns:repeat(4,1fr);gap:0;border-top:1px solid rgba(255,255,255,.08);padding-top:48px;max-width:700px">
      {[['25', 'г. опит'], ['2000', '+ дела'], ['4', 'адвокати'], ['98', '% успех']].map(([n, l], i) => (
        <div style={`padding-right:32px;${i > 0 ? 'padding-left:32px;border-left:1px solid rgba(255,255,255,.08);' : ''}`}>
          <span class="stat-num" data-target={n}>{n}</span>
          <div style="color:rgba(255,255,255,.3);font-size:11px;text-transform:uppercase;letter-spacing:.12em;margin-top:6px">{l}</div>
        </div>
      ))}
    </div>
  </div>
</div>

<!-- TICKER -->
<div style="background:var(--gold);overflow:hidden;padding:16px 0;border-top:2px solid rgba(0,0,0,.1)">
  <div class="marquee-track">
    {[...Array(2)].map(() => (
      ['Гражданско право', '·', 'Търговско право', '·', 'Недвижими имоти', '·', 'Трудово право', '·', 'Наказателно право', '·', 'Административно право', '·', 'Семейно право', '·', 'Несъстоятелност', '·'].map(item => (
        <span class="ticker-item" style={`font-size:12px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:${item === '·' ? 'rgba(15,30,53,.35)' : '#0f1e35'}`}>{item}</span>
      ))
    ))}
  </div>
</div>

<!-- ПРАКТИКИ - 3D flip cards -->
<section id="praktiki" style="background:var(--cream)">
  <div class="container">
    <div style="margin-bottom:56px" class="reveal">
      <span class="tag">Правни практики</span>
      <h2 style="font-size:clamp(1.8rem,3.5vw,2.6rem);font-weight:800;color:var(--navy);max-width:540px;line-height:1.2;font-family:'Playfair Display',serif">
        Специализирани в ключови области на правото
      </h2>
      <p style="color:#64748b;margin-top:12px;font-size:14px">Задръжте върху карта за повече информация</p>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:20px">
      {[
        { icon: '<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v18"/><line x1="3" y1="7" x2="21" y2="7"/><path d="M3 7l3 6H3"/><path d="M21 7l-3 6H21"/><path d="M6 13a3 3 0 1 0 6 0"/><path d="M12 13a3 3 0 1 0 6 0"/></svg>', title: 'Гражданско право', items: ['Облигационни отношения', 'Семейно и наследствено', 'Вещно право', 'Деликтна отговорност'], back: 'Представляваме клиенти в граждански спорове пред всички инстанции. Консултации за договори, наследство и семейни въпроси.' },
        { icon: '<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><path d="M9 22v-4h6v4"/><line x1="8" y1="6" x2="8.01" y2="6"/><line x1="16" y1="6" x2="16.01" y2="6"/><line x1="12" y1="6" x2="12.01" y2="6"/><line x1="8" y1="10" x2="8.01" y2="10"/><line x1="16" y1="10" x2="16.01" y2="10"/><line x1="12" y1="10" x2="12.01" y2="10"/><line x1="8" y1="14" x2="8.01" y2="14"/><line x1="16" y1="14" x2="16.01" y2="14"/><line x1="12" y1="14" x2="12.01" y2="14"/></svg>', title: 'Търговско право', items: ['Дружествено право', 'Договорно право', 'Търговски спорове', 'Несъстоятелност'], back: 'Правна помощ за регистрация и управление на търговски дружества, договори и разрешаване на бизнес спорове.' },
        { icon: '<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>', title: 'Недвижими имоти', items: ['Покупко-продажба', 'Наемни отношения', 'Съдебна делба', 'Вещни права'], back: 'Пълно правно съдействие при сделки с имоти — от предварителен договор до нотариален акт и вписване.' },
        { icon: '<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>', title: 'Трудово право', items: ['Трудови договори', 'Незаконно уволнение', 'Трудови спорове', 'Обезщетения'], back: 'Защита на правата на работници и работодатели. Представителство при незаконно уволнение и трудови спорове.' },
        { icon: '<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>', title: 'Наказателно право', items: ['Защита на обвиняеми', 'Частно обвинение', 'Жалби и протести', 'Реабилитация'], back: 'Ефективна защита в досъдебното и съдебното производство. Опит в сложни наказателни дела.' },
        { icon: '<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>', title: 'Административно', items: ['Административни спорове', 'Обжалване на актове', 'Разрешителни режими', 'EU право'], back: 'Обжалване на административни актове, разрешителни режими, обществени поръчки и EU регулации.' },
      ].map((p, i) => (
        <div class={`flip-card reveal`} style={`transition-delay:${(i % 3) * .1}s`}>
          <div class="flip-inner">
            <!-- Front -->
            <div class="flip-front">
              <div style="margin-bottom:16px;color:var(--navy)" set:html={p.icon} />
              <h3 style="font-size:15px;font-weight:800;color:var(--navy);margin-bottom:16px;text-transform:uppercase;letter-spacing:.06em">{p.title}</h3>
              <ul style="list-style:none;display:flex;flex-direction:column;gap:8px;margin-bottom:20px">
                {p.items.map(item => (
                  <li style="display:flex;gap:8px;font-size:13px;color:#475569">
                    <span style="color:var(--gold);flex-shrink:0">›</span>{item}
                  </li>
                ))}
              </ul>
              <div style="position:absolute;bottom:20px;right:20px;font-size:11px;color:#c4b5a0;letter-spacing:.06em">Завъртете ↗</div>
            </div>
            <!-- Back -->
            <div class="flip-back">
              <div style="margin-bottom:16px;color:var(--gold)" set:html={p.icon} />
              <h3 style="font-size:15px;font-weight:800;color:var(--gold);margin-bottom:16px;text-transform:uppercase;letter-spacing:.06em">{p.title}</h3>
              <p style="font-size:13px;color:rgba(255,255,255,.7);line-height:1.8;margin-bottom:24px">{p.back}</p>
              <a href="#konsultaciq" class="btn" style="font-size:12px;padding:10px 20px">Консултация →</a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ЕКИП -->
<section style="background:var(--navy)">
  <div class="container">
    <div style="text-align:center;margin-bottom:56px" class="reveal">
      <span class="tag">Екипът</span>
      <h2 style="font-size:clamp(1.8rem,3.5vw,2.4rem);font-weight:800;color:white;margin-bottom:12px;font-family:'Playfair Display',serif">Нашите адвокати</h2>
      <p style="color:rgba(255,255,255,.35);font-size:14px">Специалисти с доказан опит в своите области</p>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:20px">
      {[
        { name: 'Адв. Христо Петров', role: 'Управляващ съдружник', exp: '25г. опит', area: 'Търговско и гражданско право', initials: 'ХП' },
        { name: 'Адв. Елена Иванова', role: 'Съдружник',             exp: '18г. опит', area: 'Семейно и наследствено право', initials: 'ЕИ' },
        { name: 'Адв. Димитър Стоев', role: 'Старши адвокат',        exp: '12г. опит', area: 'Трудово и административно право', initials: 'ДС' },
        { name: 'Адв. Мария Колева',  role: 'Адвокат',               exp: '8г. опит',  area: 'Недвижими имоти и вещно право', initials: 'МК' },
      ].map((a, i) => (
        <div class="team-card reveal" style={`transition-delay:${i * .12}s`}>
          <div style="width:64px;height:64px;background:linear-gradient(135deg,var(--gold),#8a6520);border-radius:50%;margin-bottom:20px;display:flex;align-items:center;justify-content:center;color:var(--navy);font-size:20px;font-weight:900;transition:transform .3s" onmouseover="this.style.transform='rotate(10deg) scale(1.12)'" onmouseout="this.style.transform='rotate(0) scale(1)'">
            {a.initials}
          </div>
          <h3 style="color:white;font-size:15px;font-weight:700;margin-bottom:4px">{a.name}</h3>
          <div style="color:var(--gold);font-size:10px;text-transform:uppercase;letter-spacing:.1em;margin-bottom:12px">{a.role}</div>
          <div style="display:flex;gap:8px;align-items:center;margin-bottom:4px">
            <div style="width:4px;height:4px;background:var(--gold);border-radius:50%;flex-shrink:0"></div>
            <div style="color:rgba(255,255,255,.35);font-size:12px">{a.exp}</div>
          </div>
          <div style="display:flex;gap:8px;align-items:center">
            <div style="width:4px;height:4px;background:rgba(201,168,76,.4);border-radius:50%;flex-shrink:0"></div>
            <div style="color:rgba(255,255,255,.5);font-size:13px">{a.area}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ПРОЦЕС - Vertical timeline -->
<section style="background:white">
  <div class="container" style="max-width:800px">
    <div style="text-align:center;margin-bottom:56px" class="reveal">
      <span class="tag">Как работим</span>
      <h2 style="font-size:clamp(1.8rem,3.5vw,2.4rem);font-weight:800;color:var(--navy);font-family:'Playfair Display',serif">Ясен процес, без изненади</h2>
    </div>
    <div>
      {[
        { n: '01', title: 'Безплатна консултация', desc: '30-минутна среща (лично или онлайн). Анализираме казуса, обясняваме правата ви и очертаваме пътя напред. Без задължение.', icon: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="2" stroke-linecap="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>' },
        { n: '02', title: 'Правна стратегия', desc: 'Изготвяме детайлна правна стратегия с ясен план, реалистични срокове и честна прогноза за вероятния изход.', icon: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="2" stroke-linecap="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/></svg>' },
