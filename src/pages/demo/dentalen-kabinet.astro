---
import DemoLayout from '../../layouts/DemoLayout.astro';
---
<DemoLayout title="Дентален Кабинет Д-р Иванова — Бургас" accent="#0ea5e9">
<style>
  :root { --blue: #0369a1; --light: #e0f2fe; --dark: #0c1a2e; --text: #1e293b; }
  a { text-decoration: none; }
  .btn { background:var(--blue);color:white;font-weight:700;padding:14px 32px;display:inline-block;font-size:14px;letter-spacing:.04em;border-radius:4px;transition:background .2s;border:none;cursor:pointer; }
  .btn:hover { background:#0284c7; }
  .btn-outline { border:2px solid var(--blue);color:var(--blue);font-weight:700;padding:12px 28px;display:inline-block;font-size:14px;border-radius:4px;transition:all .2s; }
  .btn-outline:hover { background:var(--blue);color:white; }
  section { padding:80px 24px; }
  .container { max-width:1100px;margin:0 auto; }
  .tag { font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--blue);margin-bottom:12px;display:block; }
  input,select,textarea { outline:none;font-family:Inter,sans-serif; }
  input:focus,select:focus,textarea:focus { border-color:var(--blue)!important; }
</style>

<!-- NAV -->
<nav style="background:white;padding:0 32px;display:flex;align-items:center;justify-content:space-between;height:72px;position:sticky;top:32px;z-index:100;box-shadow:0 1px 20px rgba(0,0,0,.08)">
  <div style="display:flex;align-items:center;gap:12px">
    <div style="width:40px;height:40px;background:var(--blue);border-radius:50%;display:flex;align-items:center;justify-content:center;color:white;font-size:18px">🦷</div>
    <div>
      <div style="font-weight:800;font-size:16px;color:var(--dark);line-height:1">Д-р Иванова</div>
      <div style="font-size:11px;color:#94a3b8;letter-spacing:.04em">Дентален кабинет · Бургас</div>
    </div>
  </div>
  <div style="display:flex;gap:28px;align-items:center">
    {['Услуги', 'Цени', 'За нас', 'Контакти'].map(l => (
      <a href="#" style="color:#64748b;font-size:14px;font-weight:500;display:none" class="nav-link">{l}</a>
    ))}
    <a href="#zapis" class="btn" style="padding:10px 20px;font-size:13px">Запишете час</a>
  </div>
</nav>
<style>@media(min-width:768px){.nav-link{display:block!important}}</style>

<!-- HERO -->
<div style="background:linear-gradient(135deg,#f0f9ff 0%,#e0f2fe 50%,#bae6fd 100%);padding:80px 24px 60px;position:relative;overflow:hidden">
  <div style="position:absolute;right:-100px;top:-100px;width:500px;height:500px;background:radial-gradient(circle,rgba(14,165,233,.12) 0%,transparent 70%);pointer-events:none"></div>
  <div class="container" style="display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center">
    <div>
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:20px">
        <span style="color:#f59e0b;font-size:14px">★★★★★</span>
        <span style="font-size:13px;color:#64748b;font-weight:500">4.9 · 320+ отзива в Google</span>
      </div>
      <h1 style="font-size:clamp(2rem,4vw,3.2rem);font-weight:900;color:var(--dark);line-height:1.1;margin-bottom:20px">
        Вашата усмивка —<br/><span style="color:var(--blue)">нашата грижа</span>
      </h1>
      <p style="color:#475569;font-size:17px;line-height:1.7;margin-bottom:36px;max-width:480px">
        Модерен дентален кабинет с 15 години опит. Безболезнено лечение, индивидуален подход, прозрачни цени. Работим с деца и възрастни.
      </p>
      <div style="display:flex;gap:12px;flex-wrap:wrap;margin-bottom:40px">
        <a href="#zapis" class="btn">Запишете час →</a>
        <a href="#uslugi" class="btn-outline">Нашите услуги</a>
      </div>
      <div style="display:flex;gap:32px;flex-wrap:wrap">
        {[['15г.', 'Опит'], ['5000+', 'Пациенти'], ['100%', 'Безболезнено']].map(([n,l]) => (
          <div>
            <div style="font-size:1.6rem;font-weight:800;color:var(--blue)">{n}</div>
            <div style="font-size:12px;color:#94a3b8;text-transform:uppercase;letter-spacing:.06em">{l}</div>
          </div>
        ))}
      </div>
    </div>
    <div style="display:grid;gap:16px">
      {[
        { icon: '✓', text: 'Безплатен преглед при първо посещение' },
        { icon: '✓', text: 'Работим в събота 9:00–14:00' },
        { icon: '✓', text: 'Плащане на части без лихва' },
        { icon: '✓', text: 'Спешни случаи — в деня на обаждането' },
      ].map(item => (
        <div style="background:white;border-radius:8px;padding:16px 20px;display:flex;gap:12px;align-items:center;box-shadow:0 2px 12px rgba(0,0,0,.06)">
          <span style="color:var(--blue);font-weight:700;font-size:16px;flex-shrink:0">{item.icon}</span>
          <span style="font-size:14px;color:var(--text);font-weight:500">{item.text}</span>
        </div>
      ))}
    </div>
  </div>
</div>

<!-- УСЛУГИ -->
<section id="uslugi" style="background:white">
  <div class="container">
    <div style="text-align:center;margin-bottom:56px">
      <span class="tag">Нашите услуги</span>
      <h2 style="font-size:clamp(1.8rem,3.5vw,2.6rem);font-weight:800;color:var(--dark);margin-bottom:16px">Пълна дентална грижа</h2>
      <p style="color:#64748b;max-width:500px;margin:0 auto;line-height:1.7">От профилактика до естетична стоматология — всичко под един покрив.</p>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px">
      {[
        { icon: '🔍', title: 'Профилактика',      desc: 'Годишен преглед, почистване на зъбен камък, полиране. Препоръчваме 2 пъти годишно.', price: 'от 40 лв.' },
        { icon: '🦷', title: 'Лечение на кариес', desc: 'Модерни фотополимерни пломби в цвета на зъба. Безболезнена анестезия.', price: 'от 80 лв.' },
        { icon: '⚡', title: 'Избелване',          desc: 'Клинично избелване с LED технология. Резултат след 1 час. Устойчив ефект 2+ години.', price: 'от 280 лв.' },
        { icon: '👑', title: 'Коронки и мостове',  desc: 'Циркониеви коронки с 10-годишна гаранция. Цвят, форма и усещане като естествен зъб.', price: 'от 350 лв.' },
        { icon: '📐', title: 'Ортодонция',          desc: 'Брекети и прозрачни шини за деца и възрастни. Индивидуален план за лечение.', price: 'от 1200 лв.' },
        { icon: '🔩', title: 'Зъбни импланти',     desc: 'Швейцарски импланти Straumann. Доживотна гаранция. Процедурата — под 1 час.', price: 'от 1500 лв.' },
      ].map(s => (
        <div style="border:1px solid #e2e8f0;padding:28px;border-radius:8px;transition:box-shadow .2s;position:relative;overflow:hidden">
          <div style="font-size:28px;margin-bottom:16px">{s.icon}</div>
          <h3 style="font-size:17px;font-weight:700;color:var(--dark);margin-bottom:10px">{s.title}</h3>
          <p style="font-size:13px;color:#64748b;line-height:1.7;margin-bottom:16px">{s.desc}</p>
          <div style="font-size:13px;font-weight:700;color:var(--blue)">{s.price}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ЗА НАС -->
<section style="background:#f8fafc">
  <div class="container" style="display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center">
    <div>
      <span class="tag">За нас</span>
      <h2 style="font-size:clamp(1.8rem,3.5vw,2.4rem);font-weight:800;color:var(--dark);margin-bottom:24px">Д-р Мария Иванова</h2>
      <p style="color:#475569;line-height:1.8;margin-bottom:16px">
        Специалист по обща стоматология и естетична дентална медицина. Завършила Медицински университет — Варна, с специализация в Германия (Berlin Charité, 2012).
      </p>
      <p style="color:#475569;line-height:1.8;margin-bottom:32px">
        Работя с любов към всеки пациент. Вярвам, че добрата дентална грижа започва от доверието — затова всяко лечение обяснявам стъпка по стъпка, без скрити такси.
      </p>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
        {[
          ['🎓', 'МУ Варна, 2008'],
          ['🏥', 'Специализация Берлин'],
          ['🏆', '15г. практика'],
          ['❤️', '5000+ пациенти'],
        ].map(([icon, text]) => (
          <div style="display:flex;gap:10px;align-items:center">
            <span style="font-size:18px">{icon}</span>
            <span style="font-size:13px;font-weight:600;color:var(--text)">{text}</span>
          </div>
        ))}
      </div>
    </div>
    <div style="background:linear-gradient(135deg,var(--blue),#0284c7);padding:40px;border-radius:12px;color:white">
      <h3 style="font-size:20px;font-weight:700;margin-bottom:24px">Защо пациентите ни се връщат</h3>
      {[
        'Безплатен преглед при първо посещение',
        'Обясняваме всяка стъпка преди да започнем',
        'Модерно оборудване и стерилизация по EU стандарти',
        'Гъвкаво работно време вкл. събота',
        'Плащане на части без лихва',
        'Спешни часове в деня на обаждането',
      ].map(item => (
        <div style="display:flex;gap:12px;align-items:flex-start;margin-bottom:16px">
          <span style="color:#bae6fd;flex-shrink:0;margin-top:2px">✓</span>
          <span style="font-size:14px;color:rgba(255,255,255,.85);line-height:1.5">{item}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ОТЗИВИ -->
<section style="background:white">
  <div class="container">
    <div style="text-align:center;margin-bottom:48px">
      <span class="tag">Отзиви</span>
      <h2 style="font-size:clamp(1.8rem,3.5vw,2.4rem);font-weight:800;color:var(--dark)">Пациентите говорят</h2>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px">
      {[
        { name: 'Стефан К.', text: 'Отидох с огромен страх от зъболекар. Д-р Иванова беше изключително търпелива и обясни всичко детайлно. Абсолютно безболезнено! Вече не ме е страх.' },
        { name: 'Елена М.', text: 'Избелването беше невероятно — резултатът е много по-добър от очакваното. Процедурата беше бърза и удобна. Препоръчвам на всеки!' },
        { name: 'Николай Т.', text: 'Правих имплант. Страхувах се, но всичко мина гладко. Д-р Иванова е перфекционист. Вече не се усеща разлика с истинския зъб.' },
      ].map(r => (
        <div style="border:1px solid #e2e8f0;padding:28px;border-radius:8px">
          <div style="color:#f59e0b;margin-bottom:12px">★★★★★</div>
          <p style="font-size:14px;color:#475569;line-height:1.7;margin-bottom:16px;font-style:italic">"{r.text}"</p>
          <div style="font-weight:700;font-size:13px;color:var(--dark)">{r.name}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ЗАПИШЕТЕ ЧАС -->
<section id="zapis" style="background:var(--light)">
  <div class="container" style="max-width:680px">
    <div style="text-align:center;margin-bottom:48px">
      <span class="tag">Запишете час</span>
      <h2 style="font-size:clamp(1.8rem,3.5vw,2.4rem);font-weight:800;color:var(--dark);margin-bottom:12px">Запазете своя час</h2>
      <p style="color:#64748b">Потвърждение по SMS до 30 минути. Безплатен преглед при първо посещение.</p>
    </div>
    <div style="background:white;padding:40px;border-radius:12px;box-shadow:0 4px 24px rgba(0,0,0,.08)">
      <form style="display:grid;gap:20px">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
          <div>
            <label style="font-size:12px;font-weight:700;color:#475569;display:block;margin-bottom:8px;text-transform:uppercase;letter-spacing:.04em">Ime</label>
            <input type="text" placeholder="Вашето име" style="width:100%;padding:12px 16px;border:2px solid #e2e8f0;font-size:14px;border-radius:4px" />
          </div>
          <div>
            <label style="font-size:12px;font-weight:700;color:#475569;display:block;margin-bottom:8px;text-transform:uppercase;letter-spacing:.04em">Телефон</label>
            <input type="tel" placeholder="+359 88..." style="width:100%;padding:12px 16px;border:2px solid #e2e8f0;font-size:14px;border-radius:4px" />
          </div>
        </div>
        <div>
          <label style="font-size:12px;font-weight:700;color:#475569;display:block;margin-bottom:8px;text-transform:uppercase;letter-spacing:.04em">Услуга</label>
          <select style="width:100%;padding:12px 16px;border:2px solid #e2e8f0;font-size:14px;border-radius:4px;background:white">
            {['Профилактичен преглед','Лечение на кариес','Избелване','Коронка / мост','Имплант','Ортодонция','Спешен случай','Друго'].map(o => <option>{o}</option>)}
          </select>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
          <div>
            <label style="font-size:12px;font-weight:700;color:#475569;display:block;margin-bottom:8px;text-transform:uppercase;letter-spacing:.04em">Предпочитана дата</label>
            <input type="date" style="width:100%;padding:12px 16px;border:2px solid #e2e8f0;font-size:14px;border-radius:4px" />
          </div>
          <div>
            <label style="font-size:12px;font-weight:700;color:#475569;display:block;margin-bottom:8px;text-transform:uppercase;letter-spacing:.04em">Предпочитан час</label>
            <select style="width:100%;padding:12px 16px;border:2px solid #e2e8f0;font-size:14px;border-radius:4px;background:white">
              {['9:00','10:00','11:00','12:00','14:00','15:00','16:00','17:00'].map(h => <option>{h}</option>)}
            </select>
          </div>
        </div>
        <button type="submit" class="btn" style="width:100%;padding:16px;font-size:15px;border-radius:4px">Запишете час →</button>
      </form>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer style="background:var(--dark);padding:48px 24px">
  <div class="container" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:40px;margin-bottom:32px">
    <div>
      <div style="font-weight:800;font-size:18px;color:white;margin-bottom:12px">Д-р Иванова</div>
      <p style="color:rgba(255,255,255,.4);font-size:13px;line-height:1.7">Дентален кабинет · Бургас<br/>Работим с любов от 2009.</p>
    </div>
    {[
      ['Услуги', ['Профилактика', 'Лечение', 'Избелване', 'Коронки', 'Импланти', 'Ортодонция']],
      ['Контакти', ['ул. Александровска 15, Бургас', '+359 56 456 789', 'dr.ivanova@gmail.com', 'Пон–Пет: 9:00–19:00', 'Саб: 9:00–14:00']],
    ].map(([title, items]) => (
      <div>
        <div style="color:#38bdf8;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;margin-bottom:16px">{title}</div>
        <ul style="list-style:none;display:flex;flex-direction:column;gap:8px">
          {(items as string[]).map(item => <li style="color:rgba(255,255,255,.4);font-size:13px">{item}</li>)}
        </ul>
      </div>
    ))}
  </div>
  <div style="border-top:1px solid rgba(255,255,255,.1);padding-top:24px;text-align:center;color:rgba(255,255,255,.2);font-size:12px">
    © 2026 Дентален Кабинет Д-р Иванова · Бургас
  </div>
</footer>
</DemoLayout>
