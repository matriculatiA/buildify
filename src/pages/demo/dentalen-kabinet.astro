<script>
  // --- Scroll reveal ---
  const allReveal = document.querySelectorAll('.reveal, .reveal-left, .reveal-right');
  const revealIO = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) { e.target.classList.add('visible'); revealIO.unobserve(e.target); }
    });
  }, { threshold: 0.1 });
  allReveal.forEach(r => revealIO.observe(r));

  // --- Nav scroll ---
  const nav = document.getElementById('dental-nav');
  window.addEventListener('scroll', () => {
    if (nav) nav.classList.toggle('scrolled', window.scrollY > 60);
  });

  // --- Service card extra text ---
  document.querySelectorAll('.service-card').forEach(card => {
    const extra = card.querySelector('.sc-extra') as HTMLElement | null;
    card.addEventListener('mouseenter', () => { if (extra) { extra.style.opacity = '1'; extra.style.transform = 'translateY(0)'; } });
    card.addEventListener('mouseleave', () => { if (extra) { extra.style.opacity = '0'; extra.style.transform = 'translateY(8px)'; } });
  });

  // --- Progress bars ---
  const progressIO = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.querySelectorAll('.progress-fill').forEach((fill: Element) => {
          const el = fill as HTMLElement;
          const w = el.getAttribute('data-width');
          if (w) el.style.width = w + '%';
        });
        progressIO.unobserve(e.target);
      }
    });
  }, { threshold: 0.3 });
  document.querySelectorAll('.progress-bar').forEach(b => progressIO.observe(b.parentElement?.parentElement || b));

  // --- Check items animation ---
  const checkIO = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.querySelectorAll('.check-item').forEach((item: Element) => item.classList.add('visible'));
        checkIO.unobserve(e.target);
      }
    });
  }, { threshold: 0.2 });
  const checkContainer = document.querySelector('.check-item')?.closest('div');
  if (checkContainer) checkIO.observe(checkContainer);

  // --- Hide float CTA when in booking section ---
  const floatBtn = document.getElementById('float-cta');
  const zapSection = document.getElementById('zapis');
  if (floatBtn && zapSection) {
    const hideIO = new IntersectionObserver(([e]) => {
      if (floatBtn) floatBtn.style.opacity = e.isIntersecting ? '0' : '1';
    }, { threshold: 0.5 });
    hideIO.observe(zapSection);
  }
</script>
