---
import DemoLayout from '../../layouts/DemoLayout.astro';
---
<DemoLayout title="Механа Загорето — Автентична българска кухня" accent="#e8a030">
<style>
  :root { --green: #1a2e1a; --gold: #c8902a; --cream: #f5f0e8; --text: #2a1a0a; }
  * { box-sizing: border-box; }
  a { text-decoration: none; }
  .btn-primary { background: var(--gold); color: white; font-weight: 700; padding: 14px 32px; display: inline-block; font-size: 14px; letter-spacing: .06em; text-transform: uppercase; transition: background .2s; cursor: pointer; border: none; }
  .btn-primary:hover { background: #a87020; }
  .btn-outline { border: 2px solid white; color: white; font-weight: 700; padding: 12px 28px; display: inline-block; font-size: 14px; letter-spacing: .06em; text-transform: uppercase; transition: all .2s; }
  .btn-outline:hover { background: white; color: var(--green); }
  section { padding: 80px 24px; }
  .container { max-width: 1100px; margin: 0 auto; }
  .tag { font-size: 11px; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: var(--gold); margin-bottom: 12px; display: block; }

  /* Scroll reveal */
  .reveal { opacity: 0; transform: translateY(32px); transition: opacity .7s ease, transform .7s ease; }
  .reveal.visible { opacity: 1; transform: translateY(0); }
  .reveal-delay-1 { transition-delay: .1s; }
  .reveal-delay-2 { transition-delay: .2s; }
  .reveal-delay-3 { transition-delay: .3s; }

  /* Floating particles */
  @keyframes floatUp {
    0%   { transform: translateY(0) rotate(0deg); opacity: 1; }
    100% { transform: translateY(-120vh) rotate(360deg); opacity: 0; }
  }
  .particle {
    position: absolute;
    font-size: 24px;
    pointer-events: none;
    animation: floatUp linear infinite;
  }

  /* Menu tabs */
  .menu-tab { background: transparent; border: 2px solid rgba(200,144,42,.4); color: rgba(255,255,255,.6); font-weight: 700; font-size: 12px; letter-spacing: .08em; text-transform: uppercase; padding: 10px 22px; cursor: pointer; transition: all .25s; font-family: Inter, sans-serif; }
  .menu-tab:hover { border-color: var(--gold); color: var(--gold); }
  .menu-tab.active { background: var(--gold); border-color: var(--gold); color: white; }
  .menu-panel { display: none; animation: fadeIn .3s ease; }
  .menu-panel.active { display: grid; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }

  /* Review carousel */
  .reviews-track { display: flex; gap: 24px; overflow: hidden; }
  .review-card { min-width: 300px; flex-shrink: 0; border: 1px solid #e8e0d0; padding: 28px; position: relative; transition: transform .3s, box-shadow .3s; }
  .review-card:hover { transform: translateY(-4px); box-shadow: 0 12px 40px rgba(0,0,0,.12); }

  /* Gallery */
  .gallery-item { overflow: hidden; cursor: pointer; position: relative; aspect-ratio: 4/3; background: var(--green); }
  .gallery-item .overlay { position: absolute; inset: 0; background: rgba(0,0,0,.5); display: flex; align-items: center; justify-content: center; opacity: 0; transition: opacity .3s; }
  .gallery-item:hover .overlay { opacity: 1; }
  .gallery-item .fake-img { width: 100%; height: 100%; transition: transform .5s; }
  .gallery-item:hover .fake-img { transform: scale(1.08); }

  /* Sticky nav scroll effect */
  #restoran-nav { transition: background .3s, box-shadow .3s; }
  #restoran-nav.scrolled { background: rgba(15,28,15,.95) !important; backdrop-filter: blur(12px); }
</style>

<!-- NAV -->
<nav id="restoran-nav" style="background:var(--green);padding:0 32px;display:flex;align-items:center;justify-content:space-between;height:72px;position:sticky;top:32px;z-index:100;box-shadow:0 2px 20px rgba(0,0,0,.3)">
  <div style="display:flex;align-items:center;gap:8px">
    <span style="font-size:22px">🍽</span>
    <span class="serif" style="color:white;font-size:20px;font-weight:700;font-family:'Playfair Display',serif">Механа Загорето</span>
  </div>
  <div style="display:none;gap:32px" class="nav-links">
    {['Меню', 'За нас', 'Галерия', 'Резервация', 'Контакти'].map(l => (
      <a href="#" style="color:rgba(255,255,255,.7);font-size:14px;font-weight:500;transition:color .2s" onmouseover="this.style.color='#c8902a'" onmouseout="this.style.color='rgba(255,255,255,.7)'">{l}</a>
    ))}
  </div>
  <a href="#rezervacia" class="btn-primary" style="padding:10px 24px;font-size:13px">Резервирай маса</a>
</nav>
<style>@media(min-width:768px){.nav-links{display:flex!important}}</style>

<!-- HERO with floating particles -->
<div style="background:linear-gradient(135deg,#0f1e0f 0%,#1a2e1a 40%,#2d4a1e 100%);min-height:92vh;display:flex;align-items:center;position:relative;overflow:hidden" id="hero">
  <!-- Particles container -->
  <div id="particles" style="position:absolute;inset:0;pointer-events:none;overflow:hidden"></div>

  <!-- Subtle texture overlay -->
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(200,144,42,.06) 1px,transparent 1px);background-size:40px 40px;pointer-events:none"></div>

  <div class="container" style="position:relative;z-index:1;padding:60px 24px">
    <span class="tag reveal" style="font-size:12px">★ ★ ★ ★ ★ &nbsp;&nbsp; Отворени от 1994</span>
    <h1 class="serif reveal reveal-delay-1" style="color:white;font-size:clamp(2.8rem,7vw,5.5rem);line-height:1.05;margin-bottom:24px;max-width:700px;font-family:'Playfair Display',serif">
      Автентична<br/>българска кухня<br/><span style="color:var(--gold)">от сърцето на Балкана</span>
    </h1>
    <p class="reveal reveal-delay-2" style="color:rgba(255,255,255,.65);font-size:18px;line-height:1.7;max-width:520px;margin-bottom:40px">
      Домашно приготвени ястия по стари рецепти, уютна атмосфера и вина от собствено лозе. Всяка хапка — история.
    </p>
    <div class="reveal reveal-delay-3" style="display:flex;gap:16px;flex-wrap:wrap">
      <a href="#rezervacia" class="btn-primary">Резервирай маса →</a>
      <a href="#menu" class="btn-outline">Виж менюто</a>
    </div>

    <!-- Animated stats -->
    <div style="display:flex;gap:40px;margin-top:64px;flex-wrap:wrap;padding-top:40px;border-top:1px solid rgba(255,255,255,.1)">
      {[['30+', 'Години традиция'], ['200+', 'Места за гости'], ['50+', 'Ястия в менюто'], ['4.9★', 'Google рейтинг']].map(([n,l]) => (
        <div class="reveal" style="text-align:center">
          <div class="serif counter" style="color:var(--gold);font-size:2.4rem;font-weight:700;font-family:'Playfair Display',serif;line-height:1">{n}</div>
          <div style="color:rgba(255,255,255,.4);font-size:11px;text-transform:uppercase;letter-spacing:.1em;margin-top:6px">{l}</div>
        </div>
      ))}
    </div>
  </div>

  <!-- Scroll indicator -->
  <div style="position:absolute;bottom:32px;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:8px;color:rgba(255,255,255,.3);font-size:11px;letter-spacing:.1em;text-transform:uppercase">
    <span>Скролирай</span>
    <div id="scroll-arrow" style="width:2px;height:40px;background:linear-gradient(to bottom,var(--gold),transparent);animation:scrollBounce 1.5s ease-in-out infinite"></div>
  </div>
</div>
<style>
  @keyframes scrollBounce {
    0%,100% { transform: scaleY(1); opacity: 1; }
    50% { transform: scaleY(.6); opacity: .5; }
  }
</style>

<!-- INFO BAR -->
<div style="background:var(--gold)" class="reveal">
  <div class="container" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));padding:0">
    {[
      ['🕐', 'Работно време', 'Пон–Пет: 11:00–23:00\nСаб–Нед: 11:00–24:00'],
      ['📍', 'Адрес', 'ул. Витоша 42, Бургас\nдо Морската градина'],
      ['📞', 'Телефон', '+359 56 123 456\nhello@zagoreto.bg'],
      ['🅿', 'Паркинг', 'Безплатен паркинг\nза гостите ни'],
    ].map(([icon, title, info]) => (
      <div style="padding:24px 28px;border-right:1px solid rgba(255,255,255,.3);cursor:default;transition:background .2s" onmouseover="this.style.background='rgba(255,255,255,.12)'" onmouseout="this.style.background='transparent'">
        <div style="font-size:22px;margin-bottom:8px">{icon}</div>
        <div style="font-weight:700;font-size:12px;text-transform:uppercase;letter-spacing:.08em;color:rgba(0,0,0,.5);margin-bottom:4px">{title}</div>
        <div style="font-size:13px;color:#1a0a00;line-height:1.5;white-space:pre-line">{info}</div>
      </div>
    ))}
  </div>
</div>

<!-- MENU with tabs -->
<section id="menu" style="background:#0f1e0f">
  <div class="container">
    <div style="text-align:center;margin-bottom:40px" class="reveal">
      <span class="tag">Нашето меню</span>
      <h2 class="serif" style="font-size:clamp(2rem,4vw,3rem);color:white;margin-bottom:16px;font-family:'Playfair Display',serif">Вкусове от България</h2>
      <p style="color:rgba(255,255,255,.4);max-width:500px;margin:0 auto;line-height:1.7">Готвим с продукти от местни фермери. Без консерванти, без компромиси.</p>
    </div>

    <!-- Tabs -->
    <div style="display:flex;gap:8px;flex-wrap:wrap;justify-content:center;margin-bottom:40px" class="reveal">
      {['🥗 Предястия', '🍲 Основни', '🔥 Скара', '🍷 Вина & Десерти'].map((tab, i) => (
        <button class={`menu-tab${i===0?' active':''}`} data-tab={i} onclick="switchTab(this)">{tab}</button>
      ))}
    </div>

    <!-- Panel 0: Предястия -->
    <div class="menu-panel active" id="panel-0" style="grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:2px;background:rgba(255,255,255,.05)">
      {[
        ['Шопска салата', '8 лв.', 'Домати, краставици, сирене, маслини'],
        ['Кьопоолу', '9 лв.', 'Печен патладжан с чесън и орехи'],
        ['Сирене по Шопски', '11 лв.', 'Печено сирене с домати на тиган'],
        ['Луканка с краставички', '12 лв.', 'Домашна луканка, кисели краставички'],
        ['Таратор', '7 лв.', 'Кисело мляко, краставица, орехи, чесън'],
        ['Чушки бюрек', '10 лв.', 'Печени чушки с краве сирене'],
      ].map(([name, price, desc]) => (
        <div style="background:#1a2e1a;padding:20px 24px;transition:background .2s" onmouseover="this.style.background='#243d24'" onmouseout="this.style.background='#1a2e1a'">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:4px">
            <span style="font-size:15px;color:white;font-weight:600">{name}</span>
            <span style="font-weight:700;color:var(--gold);font-size:15px;margin-left:16px;flex-shrink:0">{price}</span>
          </div>
          <div style="font-size:12px;color:rgba(255,255,255,.35)">{desc}</div>
        </div>
      ))}
    </div>

    <!-- Panel 1: Основни -->
    <div class="menu-panel" id="panel-1" style="grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:2px;background:rgba(255,255,255,.05)">
      {[
        ['Кавърма с наденица', '22 лв.', 'По родопска рецепта, с домашна наденица'],
        ['Агнешко на фурна', '28 лв.', 'Бавно печено с картофи и розмарин'],
        ['Пълнени чушки', '18 лв.', 'Телешка кайма, ориз, доматен сос'],
        ['Гювеч с телешко', '24 лв.', 'Зеленчуци, телешко, подправки'],
        ['Капама', '26 лв.', 'Пиле, свинско, кисело зеле, ориз'],
        ['Боб манджа', '14 лв.', 'Бавно варен фасул с лук и чубрица'],
      ].map(([name, price, desc]) => (
        <div style="background:#1a2e1a;padding:20px 24px;transition:background .2s" onmouseover="this.style.background='#243d24'" onmouseout="this.style.background='#1a2e1a'">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:4px">
            <span style="font-size:15px;color:white;font-weight:600">{name}</span>
            <span style="font-weight:700;color:var(--gold);font-size:15px;margin-left:16px;flex-shrink:0">{price}</span>
          </div>
          <div style="font-size:12px;color:rgba(255,255,255,.35)">{desc}</div>
        </div>
      ))}
    </div>

    <!-- Panel 2: Скара -->
    <div class="menu-panel" id="panel-2" style="grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:2px;background:rgba(255,255,255,.05)">
      {[
        ['Кюфтета (3 бр.)', '14 лв.', 'Смесена кайма с чесън и кимион'],
        ['Свинска пържола', '20 лв.', 'Натурална, с масло и розмарин'],
        ['Пилешко филе', '16 лв.', 'Маринирано, с лимон и билки'],
        ['Мешана скара', '32 лв.', 'Кюфте, кебапче, пилешко, свинско'],
        ['Кебапчета (5 бр.)', '13 лв.', 'По традиционна рецепта'],
        ['Агнешки котлети', '28 лв.', 'Нежно агнешко, зелени подправки'],
      ].map(([name, price, desc]) => (
        <div style="background:#1a2e1a;padding:20px 24px;transition:background .2s" onmouseover="this.style.background='#243d24'" onmouseout="this.style.background='#1a2e1a'">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:4px">
            <span style="font-size:15px;color:white;font-weight:600">{name}</span>
            <span style="font-weight:700;color:var(--gold);font-size:15px;margin-left:16px;flex-shrink:0">{price}</span>
          </div>
          <div style="font-size:12px;color:rgba(255,255,255,.35)">{desc}</div>
        </div>
      ))}
    </div>

    <!-- Panel 3: Вина & Десерти -->
    <div class="menu-panel" id="panel-3" style="grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:2px;background:rgba(255,255,255,.05)">
      {[
        ['Домашно червено вино', '12 лв./бутилка', 'От собственото ни лозе, 2022'],
        ['Домашно бяло вино', '12 лв./бутилка', 'Свежо, полусухо, мускат'],
        ['Мастика Загорето', '4 лв./чашка', 'Домашна анасонова мастика'],
        ['Баница с мед', '6 лв.', 'Топла, с домашен мед и орехи'],
        ['Тиквеник', '5 лв.', 'По баническа рецепта, с тиква'],
        ['Крем карамел', '7 лв.', 'Домашен, с карамелен сос'],
      ].map(([name, price, desc]) => (
        <div style="background:#1a2e1a;padding:20px 24px;transition:background .2s" onmouseover="this.style.background='#243d24'" onmouseout="this.style.background='#1a2e1a'">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:4px">
            <span style="font-size:15px;color:white;font-weight:600">{name}</span>
            <span style="font-weight:700;color:var(--gold);font-size:15px;margin-left:16px;flex-shrink:0">{price}</span>
          </div>
          <div style="font-size:12px;color:rgba(255,255,255,.35)">{desc}</div>
        </div>
      ))}
    </div>

    <div style="text-align:center;margin-top:32px" class="reveal">
      <a href="#rezervacia" class="btn-primary">Запазете маса →</a>
    </div>
  </div>
</section>

<!-- GALLERY -->
<section style="background:var(--cream);padding:80px 24px">
  <div class="container">
    <div style="text-align:center;margin-bottom:40px" class="reveal">
      <span class="tag">Атмосфера</span>
      <h2 class="serif" style="font-size:clamp(1.8rem,3.5vw,2.8rem);color:var(--text);font-family:'Playfair Display',serif">Усетете духа на механата</h2>
    </div>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);grid-template-rows:auto auto;gap:12px">
      {[
        { bg: 'linear-gradient(135deg,#2d1a0a,#4a2e10)', emoji: '🍽', label: 'Уютна зала', span: 'col-span-2' },
        { bg: 'linear-gradient(135deg,#1a2e1a,#2d4a1e)', emoji: '🌿', label: 'Градинска тераса', span: '' },
        { bg: 'linear-gradient(135deg,#3d1f00,#6b3800)', emoji: '🥩', label: 'Скара на жар', span: '' },
        { bg: 'linear-gradient(135deg,#1a1a0a,#3d3d1a)', emoji: '🍷', label: 'Наш избор', span: '' },
        { bg: 'linear-gradient(135deg,#0a1a0a,#1a3a1a)', emoji: '🎵', label: 'Живa музика', span: 'col-span-2' },
      ].map((item, i) => (
        <div class="gallery-item reveal" style={`${i===0?'grid-column:span 2':''}${i===4?'grid-column:span 2':''};background:${item.bg};border-radius:2px`}>
          <div class="fake-img" style={`background:${item.bg};width:100%;height:200px;display:flex;align-items:center;justify-content:center`}>
            <span style="font-size:64px;opacity:.6">{item.emoji}</span>
          </div>
          <div class="overlay">
            <span style="color:white;font-weight:700;font-size:14px;letter-spacing:.06em;text-transform:uppercase">{item.label}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ABOUT -->
<section style="background:var(--green)">
  <div class="container" style="display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center">
    <div class="reveal">
      <span class="tag">За нас</span>
      <h2 class="serif" style="color:white;font-size:clamp(1.8rem,3.5vw,2.8rem);margin-bottom:24px;font-family:'Playfair Display',serif">Три поколения на трапезата</h2>
      <p style="color:rgba(255,255,255,.65);line-height:1.8;margin-bottom:20px">
        Механа Загорето е основана от баба Мария Петрова през 1994 година с мечтата да съхрани автентичния вкус на родопската кухня. Днес, три десетилетия по-късно, продължаваме традицията с рецептите, предадени от поколение на поколение.
      </p>
      <p style="color:rgba(255,255,255,.65);line-height:1.8;margin-bottom:32px">
        Всяко ястие се приготвя с пресни, сезонни продукти от местни производители. Виното ни е от собственото ни лозе — бяло и червено, отлежало в дъбови бурета.
      </p>
      <a href="#rezervacia" class="btn-primary">Резервирай →</a>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px" class="reveal">
      {[
        { n: '⭐ 4.9', t: 'Google рейтинг' },
        { n: '1200+', t: 'Отзива' },
        { n: '30г.', t: 'Традиция' },
        { n: '100%', t: 'Домашно готвене' },
      ].map(s => (
        <div style="background:rgba(255,255,255,.07);padding:28px;text-align:center;border:1px solid rgba(255,255,255,.1);transition:background .3s,transform .3s;cursor:default" onmouseover="this.style.background='rgba(200,144,42,.15)';this.style.transform='scale(1.04)'" onmouseout="this.style.background='rgba(255,255,255,.07)';this.style.transform='scale(1)'">
          <div class="serif" style="color:var(--gold);font-size:1.8rem;font-weight:700;margin-bottom:8px;font-family:'Playfair Display',serif">{s.n}</div>
          <div style="color:rgba(255,255,255,.45);font-size:11px;text-transform:uppercase;letter-spacing:.1em">{s.t}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- REVIEWS - Carousel -->
<section style="background:white;overflow:hidden">
  <div class="container">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:40px" class="reveal">
      <div>
        <span class="tag">Отзиви</span>
        <h2 class="serif" style="font-size:clamp(1.8rem,3.5vw,2.8rem);color:var(--text);font-family:'Playfair Display',serif">Какво казват гостите</h2>
      </div>
      <div style="display:flex;gap:8px">
        <button id="prev-review" onclick="moveCarousel(-1)" style="width:44px;height:44px;border:2px solid #ddd;background:white;font-size:18px;cursor:pointer;transition:all .2s;display:flex;align-items:center;justify-content:center" onmouseover="this.style.borderColor='var(--gold)';this.style.color='var(--gold)'" onmouseout="this.style.borderColor='#ddd';this.style.color='inherit'">‹</button>
        <button id="next-review" onclick="moveCarousel(1)" style="width:44px;height:44px;border:2px solid #ddd;background:white;font-size:18px;cursor:pointer;transition:all .2s;display:flex;align-items:center;justify-content:center" onmouseover="this.style.borderColor='var(--gold)';this.style.color='var(--gold)'" onmouseout="this.style.borderColor='#ddd';this.style.color='inherit'">›</button>
      </div>
    </div>
    <div style="overflow:hidden">
      <div class="reviews-track" id="reviews-track">
        {[
          { name: 'Мария С.', stars: 5, text: 'Най-добрите кюфтета, които съм яла! Атмосферата е невероятна, усещаш се като у дома. Определено ще се върна.', date: 'Февруари 2026' },
