<script>
  // --- Floating Particles ---
  const emojis = ['🍽','🥩','🍷','🌿','🫙','🥗','🔥'];
  const container = document.getElementById('particles');
  function spawnParticle() {
    if (!container) return;
    const el = document.createElement('div');
    el.className = 'particle';
    el.textContent = emojis[Math.floor(Math.random() * emojis.length)];
    el.style.left = Math.random() * 100 + '%';
    el.style.bottom = '-40px';
    const dur = 8 + Math.random() * 12;
    el.style.animationDuration = dur + 's';
    el.style.animationDelay = Math.random() * 4 + 's';
    el.style.fontSize = (16 + Math.random() * 20) + 'px';
    el.style.opacity = (0.15 + Math.random() * 0.25).toString();
    container.appendChild(el);
    setTimeout(() => el.remove(), (dur + 4) * 1000);
  }
  for (let i = 0; i < 12; i++) setTimeout(spawnParticle, i * 600);
  setInterval(spawnParticle, 2000);

  // --- Scroll reveal ---
  const reveals = document.querySelectorAll('.reveal');
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); } });
  }, { threshold: 0.12 });
  reveals.forEach(r => io.observe(r));

  // --- Nav scroll effect ---
  const nav = document.getElementById('restoran-nav');
  window.addEventListener('scroll', () => {
    if (nav) nav.classList.toggle('scrolled', window.scrollY > 60);
  });

  // --- Menu tabs ---
  function switchTab(btn) {
    document.querySelectorAll('.menu-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.menu-panel').forEach(p => p.classList.remove('active'));
    btn.classList.add('active');
    const idx = btn.getAttribute('data-tab');
    document.getElementById('panel-' + idx)?.classList.add('active');
  }

  // --- Review carousel ---
  let carouselIdx = 0;
  const track = document.getElementById('reviews-track');
  const dotsContainer = document.getElementById('review-dots');
  const totalReviews = 5;
  const visibleCount = () => window.innerWidth < 640 ? 1 : window.innerWidth < 1024 ? 2 : 3;

  function buildDots() {
    if (!dotsContainer) return;
    dotsContainer.innerHTML = '';
    const maxIdx = totalReviews - visibleCount();
    for (let i = 0; i <= maxIdx; i++) {
      const dot = document.createElement('div');
      dot.style.cssText = `width:8px;height:8px;border-radius:50%;background:${i === carouselIdx ? '#c8902a' : '#ddd'};cursor:pointer;transition:background .2s`;
      dot.onclick = () => { carouselIdx = i; updateCarousel(); };
      dotsContainer.appendChild(dot);
    }
  }

  function updateCarousel() {
    if (!track) return;
    const cardWidth = 324; // 300px + 24px gap
    track.style.transform = `translateX(-${carouselIdx * cardWidth}px)`;
    track.style.transition = 'transform .4s cubic-bezier(.25,.46,.45,.94)';
    buildDots();
  }

  function moveCarousel(dir) {
    const max = totalReviews - visibleCount();
    carouselIdx = Math.max(0, Math.min(max, carouselIdx + dir));
    updateCarousel();
  }

  buildDots();
  // Auto-advance
  setInterval(() => moveCarousel(carouselIdx >= totalReviews - visibleCount() ? -(totalReviews - visibleCount()) : 1), 5000);
</script>
