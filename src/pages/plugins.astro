  </style>

  <script>
  function calcM() {
    const price = +document.getElementById('mp')?.value || 200000;
    const dpct  = +document.getElementById('mslider')?.value || 20;
    const rate  = +document.getElementById('mr')?.value || 3.5;
    const yrs   = +document.getElementById('my')?.value || 25;
    const down  = price * dpct / 100;
    const loan  = price - down;
    const mo    = rate / 100 / 12;
    const n     = yrs * 12;
    const mth   = mo === 0 ? loan/n : loan * mo * Math.pow(1+mo,n) / (Math.pow(1+mo,n)-1);
    const tot   = mth * n;
    const fmt   = v => Math.round(v).toLocaleString('bg-BG') + ' лв.';
    if (!document.getElementById('mres')) return;
    document.getElementById('mslider-lbl').textContent = dpct + '% = ' + fmt(down);
    document.getElementById('mres').textContent = fmt(mth);
    document.getElementById('mloаn').textContent = fmt(loan);
    document.getElementById('mtot').textContent  = fmt(tot);
    document.getElementById('mint').textContent  = fmt(tot - loan);
    document.getElementById('mltv').textContent  = Math.round(loan / price * 100) + '%';
  }

  const DAYS_BG   = ['нд','пн','вт','ср','чт','пт','сб'];
  const MONTHS_BG = ['яну','фев','мар','апр','май','юни','юли','авг','сеп','окт','ное','дек'];
  let bkWeekOffset = 0;
  let bkSelDate = null;

  function bkGetWeekStart(offset) {
    const d = new Date(); d.setHours(0,0,0,0);
    const dow = d.getDay();
    const diff = dow === 0 ? -6 : 1 - dow;
    d.setDate(d.getDate() + diff + offset * 7);
    return d;
  }

  function bkRenderWeek() {
    const ws = bkGetWeekStart(bkWeekOffset);
    const we = new Date(ws); we.setDate(ws.getDate() + 6);
    const lbl = document.getElementById('bk-week-lbl');
    if (lbl) lbl.textContent = ws.getDate() + ' ' + MONTHS_BG[ws.getMonth()] + ' - ' + we.getDate() + ' ' + MONTHS_BG[we.getMonth()];
    const grid = document.getElementById('bk-cal-grid');
    if (!grid) return;
    let html = '';
    for (let i = 0; i < 7; i++) {
      const d = new Date(ws); d.setDate(ws.getDate() + i);
      html += `<div class="bk-dhdr">${DAYS_BG[d.getDay()]}</div>`;
    }
    const today = new Date(); today.setHours(0,0,0,0);
    for (let i = 0; i < 7; i++) {
      const d = new Date(ws); d.setDate(ws.getDate() + i);
      const isOff  = d.getDay() === 0 || d.getDay() === 6;
      const isPast = d < today;
      const iso    = d.toISOString().split('T')[0];
      const isSel  = bkSelDate === iso;
      const cls    = `bk-d${isOff||isPast?' off':''}${isSel?' sel':''}`;
      html += `<div class="${cls}" data-iso="${iso}" ${isOff||isPast?'':'onclick="bkSelectDay(this)"'}><span class="bk-d-num">${d.getDate()}</span></div>`;
    }
    grid.innerHTML = html;
  }

  function bkSelectDay(el) {
    bkSelDate = el.dataset.iso;
    bkRenderWeek();
    const busy  = ['10:00','14:00'];
    const slots = ['09:00','10:00','11:00','13:00','14:00','15:00','16:00'];
    document.getElementById('bk-tw').style.display = 'block';
    document.getElementById('bk-slots').innerHTML = slots.map(t =>
      `<button class="bk-t${busy.includes(t)?' busy':''}" onclick="pickTime(this)" ${busy.includes(t)?'disabled':''}>${t}</button>`
    ).join('');
    document.getElementById('bk-cw').style.display = 'none';
    document.getElementById('bk-succ').innerHTML = '';
  }

  function bkPrevWeek() { bkWeekOffset--; bkSelDate=null; bkRenderWeek(); document.getElementById('bk-tw').style.display='none'; document.getElementById('bk-cw').style.display='none'; }
  function bkNextWeek() { bkWeekOffset++; bkSelDate=null; bkRenderWeek(); document.getElementById('bk-tw').style.display='none'; document.getElementById('bk-cw').style.display='none'; }

  function initBook() { bkRenderWeek(); }

  function pickTime(btn) {
    document.querySelectorAll('.bk-t').forEach(b => b.classList.remove('sel'));
    btn.classList.add('sel');
    document.getElementById('bk-cw').style.display = 'block';
  }
  function confirmBk() {
    const name = document.getElementById('bk-name').value.trim();
    if (!name) return;
    const svc  = document.getElementById('bk-svc').value;
    const time = document.querySelector('.bk-t.sel')?.textContent || '09:00';
    const d    = new Date(bkSelDate);
    const dateStr = d.getDate() + ' ' + MONTHS_BG[d.getMonth()];
    document.getElementById('bk-cw').style.display = 'none';
    document.getElementById('bk-succ').innerHTML = `<div class="bk-success">✓ Записани сте!<br><span style="font-size:9px;color:#6b9470;display:block;margin-top:4px">${name} · ${svc} · ${dateStr} · ${time} · BLD-${Math.floor(Math.random()*9000)+1000}</span></div>`;
  }

  const chatR = [
    'Buildify.bg предлага уебсайтове от 350€, плъгини от 150€ и AI ботове от 200€.',
    'Това е демо версия. Реалният бот се обучава с информацията за вашия бизнес.',
    'Разработваме за Бургас и цяла България. Свържете се за безплатна консултация!',
    'Отговаряме до 48 часа. Пишете на /contact или contact@buildify.bg.',
    'Всеки плъгин е по мярка — точно каквото ви трябва, нищо повече.',
  ];
  let chatIdx = 0;
  function sendChatDemo() {
    const inp  = document.getElementById('chat-inp');
    const msgs = document.getElementById('chat-msgs');
    const text = inp.value.trim();
    if (!text) return;
    inp.value = '';
    msgs.innerHTML += `<div class="msg-me">${text}</div>`;
    msgs.innerHTML += `<div class="msg-typing" id="chat-typing"><span></span><span></span><span></span></div>`;
    msgs.scrollTop = msgs.scrollHeight;
    setTimeout(() => {
      document.getElementById('chat-typing')?.remove();
      msgs.innerHTML += `<div class="msg-ai">${chatR[chatIdx % chatR.length]}</div>`;
      chatIdx++;
      msgs.scrollTop = msgs.scrollHeight;
    }, 850);
  }

  function calcBMI() {
    const h   = +document.getElementById('bmi-h')?.value || 175;
    const w   = +document.getElementById('bmi-w')?.value || 75;
    const bmi = w / ((h/100) * (h/100));
    let color, cat, advice;
    if      (bmi < 18.5) { color='#5a8fc4'; cat='Поднормено тегло'; advice='Препоръчва се консултация с диетолог.'; }
    else if (bmi < 25)   { color='#c47a52'; cat='Нормално тегло';   advice='Отлично! Поддържай здравословен начин на живот.'; }
    else if (bmi < 30)   { color='#c49a52'; cat='Наднормено тегло'; advice='Препоръчва се повече физическа активност.'; }
    else                  { color='#c45252'; cat='Затлъстяване';     advice='Препоръчва се консултация с лекар.'; }
    const idealLow  = Math.round(18.5 * (h/100) * (h/100));
    const idealHigh = Math.round(24.9 * (h/100) * (h/100));
    const pct = Math.min(Math.max((bmi - 10) / 30 * 100, 0), 100);
    if (!document.getElementById('bmi-val')) return;
    document.getElementById('bmi-val').textContent  = bmi.toFixed(1);
    document.getElementById('bmi-cat').textContent  = cat;
    document.getElementById('bmi-result').style.background = color + '22';
    document.getElementById('bmi-rval-c').style.color = color;
    document.getElementById('bmi-fill').style.width      = pct + '%';
    document.getElementById('bmi-fill').style.background = color;
    document.getElementById('bmi-ideal').textContent  = 'Идеално тегло: ' + idealLow + '-' + idealHigh + ' кг';
    document.getElementById('bmi-advice').textContent = advice;
  }

  function calcUtil() {
    const type = document.getElementById('ut-type')?.value;
    const qty  = +document.getElementById('ut-qty')?.value || 0;
    let res = '', unit = '', tip = '';
    if (type === 'elec') {
      const d = qty * 0.35;
      res = (d * 30).toFixed(2) + ' лв.'; unit = 'месечна сметка';
      tip = qty + ' kWh/ден x 0.35 лв. = ' + d.toFixed(2) + ' лв./ден';
    } else if (type === 'water') {
      res = (qty * 4.50).toFixed(2) + ' лв.'; unit = 'месечна сметка';
      tip = qty + ' m3 x 4.50 лв./m3';
    } else {
      const price = +document.getElementById('ut-price')?.value || 2.80;
      const km    = +document.getElementById('ut-km')?.value || 1000;
      res = (km / 100 * qty * price).toFixed(2) + ' лв.'; unit = 'разход за ' + km + ' км';
      tip = km + ' км / ' + qty + ' л/100км x ' + price + ' лв.';
    }
    if (!document.getElementById('ut-res')) return;
    document.getElementById('ut-res').textContent = res;
    document.getElementById('ut-lbl').textContent = unit;
    document.getElementById('ut-tip').textContent = tip;
    const fe = document.getElementById('ut-fuel');
    if (fe) fe.style.display = type === 'fuel' ? 'grid' : 'none';
  }

  function submitForm() {
    const name  = document.getElementById('cf-name')?.value.trim();
    const email = document.getElementById('cf-email')?.value.trim();
    const msg   = document.getElementById('cf-msg')?.value.trim();
    if (!name || !email || !msg) { alert('Попълни всички полета'); return; }
    document.getElementById('cf-form-inner').style.display = 'none';
    document.getElementById('cf-succ').style.display = 'block';
  }
  function resetForm() {
    document.getElementById('cf-form-inner').style.display = 'block';
    document.getElementById('cf-succ').style.display = 'none';
    ['cf-name','cf-email','cf-msg'].forEach(id => { const el = document.getElementById(id); if(el) el.value=''; });
  }



  function switchTab(idx) {
    document.querySelectorAll('.tab-btn').forEach((b,i) => b.classList.toggle('active', i===idx));
    document.querySelectorAll('.tab-panel').forEach((p,i) => p.classList.toggle('active', i===idx));
  }

