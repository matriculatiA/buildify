      { num:'01', name:'Ипотечен калкулатор', desc:'Клиентът вижда месечната вноска преди да ви потърси — идва информиран и готов за разговор.', tags:['Имоти','Банки','Строители'], price:'от 150€', for:'Агенции за имоти · банки · строителни компании' },
      { num:'02', name:'Резервационна система', desc:'Записвания онлайн 24/7 — без телефонни обаждания, без пропуснати часове.', tags:['Лекари','Ресторанти','Услуги'], price:'от 300€', for:'Лекарски кабинети · ресторанти · салони за красота · всякакви услуги' },
      { num:'03', name:'AI чатбот', desc:'Отговаря вместо вас — по всяко време, с вашия тон и вашите отговори.', tags:['Всеки бизнес','24/7'], price:'от 200€', for:'Всеки бизнес с повтарящи се въпроси от клиенти' },
      { num:'04', name:'BMI калкулатор', desc:'Персонален резултат за всеки посетител — ангажира и насочва към следваща стъпка.', tags:['Фитнес','Здраве','Хранене'], price:'от 150€', for:'Фитнес зали · диетолози · спортни клубове · аптеки' },
      { num:'05', name:'Комунален калкулатор', desc:'Помага на клиента да планира разходите — доверие от първата секунда.', tags:['Енергия','Имоти','Комунални'], price:'от 150€', for:'Агенции за имоти · комунални фирми · строители' },
      { num:'06', name:'Контактна форма', desc:'Структурирано запитване с точно нужното — по-малко имейли напред-назад.', tags:['Всеки бизнес','Лийдове'], price:'от 150€', for:'Всеки бизнес — включена безплатно с всеки уебсайт от buildify' },
    ];

    const tabNav = meta.map((m,i) =>
      `<button class="tab-btn${i===0?' active':''}" onclick="switchTab(${i})"><span class="tab-btn-num">${m.num}</span><span class="tab-btn-name">${m.name}</span></button>`
    ).join('');

    const panels = widgets.map((w, i) => {
      const m = meta[i];
      const tags = m.tags.map(t=>`<span class="tp-tag">${t}</span>`).join('');
      return `<div class="tab-panel${i===0?' active':''}" data-panel="${i}">
        <div class="tp-demo">${w}</div>
        <div class="tp-text">
          <span class="tp-num">${m.num}</span>
          <div class="tp-name">${m.name}</div>
          <div class="tp-desc">${m.desc}</div>
          <div class="tp-for">Подходящо за: ${m.for}</div>
          <div class="tp-tags">${tags}</div>
          <div class="tp-price">${m.price}<span class="tp-price-note">еднократно · без абонамент</span></div>
          <a href="/contact" class="tp-cta">Поискай оферта →</a>
        </div>
      </div>`;
    }).join('');

    const isMobile = window.innerWidth <= 768;

    if (!isMobile) {
      // ── DESKTOP: sidebar + panels ──────────────────
      document.getElementById('plugin-tabs').innerHTML =
        `<div class="tab-layout"><div class="tab-sidebar">${tabNav}</div><div class="tab-content">${panels}</div></div>`;
    } else {
      // ── MOBILE: peek carousel ──────────────────────
      const mcInfoHtml = (i) => {
        const m = meta[i];
        return `<span class="mc-num">${m.num}</span><div class="mc-name">${m.name}</div><div class="mc-desc">${m.desc}</div><div class="mc-tags">${m.tags.map(t=>`<span class="mc-tag">${t}</span>`).join('')}</div>`;
      };
      const mcSlides = widgets.map((w,i)=>`<div class="mc-slide" data-idx="${i}">${w}</div>`).join('');
      const mcDots   = meta.map((_,i)=>`<button class="mc-dot${i===0?' active':''}" onclick="mcGoTo(${i})"></button>`).join('');

      document.getElementById('plugin-tabs').innerHTML = `
        <div class="mobile-carousel">
          <div class="mc-info" id="mc-info">${mcInfoHtml(0)}</div>
          <div class="mc-wrap" id="mc-wrap">
            <div class="mc-track" id="mc-track">${mcSlides}</div>
            <button class="mc-btn mc-btn-prev" id="mc-prev" onclick="mcPrev()" disabled>&#8592;</button>
            <button class="mc-btn mc-btn-next" id="mc-next" onclick="mcNext()">&#8594;</button>
          </div>
          <div class="mc-footer">
            <div class="mc-dots">${mcDots}</div>
          </div>
        </div>`;

      let mcCur = 0;
      function mcGoTo(i) {
        mcCur = i;
        const wrap  = document.getElementById('mc-wrap');
        const track = document.getElementById('mc-track');
        if (track && wrap) track.style.transform = `translateX(-${i * (wrap.offsetWidth - 72)}px)`;
        const info = document.getElementById('mc-info');
        if (info) info.innerHTML = mcInfoHtml(i);
        document.querySelectorAll('.mc-dot').forEach((d,j) => d.classList.toggle('active', j===i));
        const prev = document.getElementById('mc-prev');
        const next = document.getElementById('mc-next');
        if (prev) prev.disabled = i === 0;
        if (next) next.disabled = i === meta.length - 1;
      }
      function mcPrev() { if (mcCur > 0) mcGoTo(mcCur - 1); }
      function mcNext() { if (mcCur < meta.length - 1) mcGoTo(mcCur + 1); }

      // Touch/swipe support
      let mcTouchX = 0;
      const mcWrapEl = document.getElementById('mc-wrap');
      if (mcWrapEl) {
        mcWrapEl.addEventListener('touchstart', e => { mcTouchX = e.touches[0].clientX; }, { passive: true });
        mcWrapEl.addEventListener('touchend',   e => {
          const diff = mcTouchX - e.changedTouches[0].clientX;
          if (Math.abs(diff) > 40) diff > 0 ? mcNext() : mcPrev();
        });
      }

      window.mcGoTo=mcGoTo; window.mcPrev=mcPrev; window.mcNext=mcNext;
    }

    initBook(); calcM(); calcBMI(); calcUtil();
    window.calcM=calcM; window.calcBMI=calcBMI; window.calcUtil=calcUtil;
    window.pickTime=pickTime; window.confirmBk=confirmBk; window.bkPrevWeek=bkPrevWeek; window.bkNextWeek=bkNextWeek; window.bkSelectDay=bkSelectDay;
    window.sendChatDemo=sendChatDemo; window.submitForm=submitForm; window.resetForm=resetForm;
    window.switchTab=switchTab;
  });
  </script>

    <!-- Pricing -->
  <section class="bg-ink border-b-2 border-ink">
    <div class="border-b-2 border-yellow/20 px-8 py-5">
      <span class="font-mono text-xs uppercase tracking-widest text-white/30 font-bold">03 · Цена</span>
    </div>
    <div class="grid md:grid-cols-3 divide-y-2 md:divide-y-0 md:divide-x-2 divide-white/10">
      {[
        { range: "от 150€",  label: "Прост плъгин", examples: "Калкулатор · форма · ограничение на достъп" },
        { range: "от 300€",  label: "Среден плъгин", examples: "Резервационна система · API интеграция · чатбот" },
        { range: "от 750€",  label: "Комплексен плъгин", examples: "Admin табло · сложна бизнес логика · многостъпков процес" },
      ].map(tier => (
        <div class="p-8">
          <div class="font-mono font-bold text-yellow text-3xl mb-1">{tier.range}</div>
          <div class="text-white/70 text-sm font-bold mb-2 uppercase tracking-wide">{tier.label}</div>
          <div class="text-white/35 text-xs leading-relaxed">{tier.examples}</div>
        </div>
      ))}
    </div>
    <div class="border-t-2 border-white/10 px-8 py-8 flex flex-col md:flex-row md:items-center gap-4">
      <a href="/contact" class="inline-flex items-center gap-3 bg-yellow text-ink font-bold text-sm px-8 py-4 uppercase tracking-wide hover:bg-yellow-dark transition-colors">
        Опиши нуждата — оценяваме безплатно →
      </a>
      <span class="text-white/30 text-xs font-mono">Еднократно плащане · без абонамент · QA тест включен</span>
    </div>
  </section>
</BaseLayout>
