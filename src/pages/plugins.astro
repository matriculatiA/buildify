---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icons.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Разработка на custom плъгини и добавки",
  "provider": { "@type": "Organization", "name": "buildify.bg", "url": "https://buildify.bg" },
  "description": "Custom плъгини и добавки по мярка. Конкретна функционалност без тежки готови решения. От 150€.",
  "areaServed": "Bulgaria"
};

const examples = [
  { icon: "plugin",    title: "Калкулатори",            desc: "Ценови калкулатор, ипотечен калкулатор, оферти - всичко интерактивно и вградено в сайта." },
  { icon: "clock",     title: "Резервационни системи",  desc: "Записване за часове, резервации на маси, регистрации за събития." },
  { icon: "seo",       title: "API интеграции",         desc: "Свързване на сайта с CRM, счетоводна система, куриерска фирма или друг external service." },
  { icon: "form-broken", title: "Форми и автоматизация", desc: "Сложни многостъпкови форми с условна логика и автоматични имейли." },
  { icon: "no-fee",    title: "Сигурност и ограничения",desc: "Ограничаване на достъп, watermarking на снимки, защита на съдържание." },
  { icon: "star",      title: "Табла и отчети",         desc: "Admin панели за управление на специфична бизнес логика директно от сайта." },
];
---

<BaseLayout
  title="Разработка на custom плъгини | buildify.bg"
  description="Custom плъгини и добавки по мярка. Само каквото ти трябва - без тежки готови решения. От 150€."
  schema={schema}
>
  <!-- Hero split -->
  <section class="border-b-2 border-ink grid md:grid-cols-2 min-h-[55vh]">
    <div class="bg-ink text-white px-8 md:px-14 py-16 flex flex-col justify-between">
      <span class="font-mono text-xs text-white/45 uppercase tracking-widest">buildify.bg / Плъгини</span>
      <div>
        <h1 class="font-bold text-white leading-tight tracking-tightest mb-5" style="font-size:clamp(2.5rem,6vw,4.5rem)">
          Custom плъгини<br/>за сайта ти.<br/>
          <span class="bg-yellow text-ink px-2">По мярка.</span>
        </h1>
        <p class="text-white/40 text-base leading-relaxed max-w-sm">
          Вместо тежки плъгини с 200 функции от които ползваш 3 - правим лека добавка, която прави точно нужното.
        </p>
      </div>
      <a href="/contact" class="inline-flex items-center gap-3 bg-yellow text-ink font-bold text-sm px-7 py-4 uppercase tracking-wide hover:bg-yellow-dark transition-colors w-fit">
        Опиши нуждата си →
      </a>
    </div>
    <div class="bg-cream px-8 md:px-14 py-16 flex flex-col justify-center gap-5 border-t-2 md:border-t-0 md:border-l-2 border-ink">
      {[
        { num: "01", title: "Описваш нуждата",           desc: "Казваш ни какво трябва да прави. Без технически детайли." },
        { num: "02", title: "Правим спецификация",       desc: "Разписваме точно какво ще се направи и на каква цена." },
        { num: "03", title: "Разработваме и тестваме",   desc: "Чист, документиран код. QA тест включен." },
        { num: "04", title: "Инсталираме и обучаваме",   desc: "Инсталираме на сайта ти и обясняваме как се ползва." },
      ].map(step => (
        <div class="flex gap-4 items-start">
          <span class="font-mono font-bold text-ink/20 text-2xl shrink-0 w-10">{step.num}</span>
          <div>
            <div class="font-bold text-sm uppercase tracking-tight text-ink mb-0.5">{step.title}</div>
            <div class="text-xs text-muted leading-relaxed">{step.desc}</div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Tech strip -->
  <section class="bg-yellow border-b-2 border-ink">
    <div class="grid grid-cols-2 md:grid-cols-4 divide-x-2 divide-ink">
      {[
        { name: "Web / CMS",     desc: "Платформа"              },
        { name: "PHP / JS",      desc: "Технологии"             },
        { name: "Интеграции",    desc: "API, CRM, системи"      },
        { name: "Без абонамент", desc: "Еднократно плащане"     },
      ].map(t => (
        <div class="py-5 px-6 text-center">
          <div class="font-mono font-bold text-ink text-base">{t.name}</div>
          <div class="text-xs text-ink/50 mt-0.5">{t.desc}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Examples -->
  <section class="bg-cream border-b-2 border-ink">
    <div class="border-b-2 border-ink px-8 py-5">
      <span class="font-mono text-xs uppercase tracking-widest text-muted font-bold">01 · Примери</span>
    </div>
    <div class="grid md:grid-cols-3 divide-y-2 md:divide-y-0 divide-ink">
      {examples.map((ex, i) => (
        <div class={`p-8 border-b-2 md:border-b-0 border-ink ${i % 3 !== 2 ? 'md:border-r-2' : ''} ${i >= 3 ? 'border-b-0' : ''}`}>
          <div class="mb-4"><Icon name={ex.icon} size={32} /></div>
          <h3 class="font-bold text-base uppercase tracking-tight text-ink mb-2">{ex.title}</h3>
          <p class="text-muted text-sm leading-relaxed">{ex.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- LIVE DEMOS -->
  <section class="border-b-2 border-ink">
    <div class="border-b-2 border-ink px-8 py-5">
      <span class="font-mono text-xs uppercase tracking-widest font-bold text-muted">02 · Демо плъгини — пробвай ги сега</span>
    </div>
    <div id="plugin-tabs"></div>
  </section>

  <style is:global>
    /* ── SIDEBAR LAYOUT ─────────────────────────── */
    .tab-layout { display: grid; grid-template-columns: 220px 1fr; }
    .tab-sidebar { background: #111; border-right: 2px solid #111; display: flex; flex-direction: column; }
    .tab-content { position: relative; }

    .tab-btn { display: flex; flex-direction: column; gap: 4px; padding: 18px 20px 18px 22px; border: none; border-bottom: 1px solid rgba(255,255,255,.07); border-left: 3px solid transparent; background: transparent; cursor: pointer; text-align: left; width: 100%; transition: background .15s; }
    .tab-btn:hover { background: rgba(255,255,255,.05); }
    .tab-btn.active { background: #1c1c1c; border-left-color: #f5e642; }
    .tab-btn-num  { font-family: 'Space Mono', monospace; font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: rgba(255,255,255,.22); transition: color .15s; }
    .tab-btn-name { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .04em; color: rgba(255,255,255,.38); line-height: 1.35; transition: color .15s; }
    .tab-btn.active .tab-btn-num  { color: #f5e642; }
    .tab-btn.active .tab-btn-name { color: white; }
    .tab-btn:hover .tab-btn-name  { color: rgba(255,255,255,.65); }

    /* ── TAB PANELS ──────────────────────────────── */
    .tab-panel { display: none; }
    .tab-panel.active { display: grid; grid-template-columns: 1fr 1fr; min-height: 540px; }

    .tp-demo { display: flex; align-items: center; justify-content: center; padding: 52px 44px; border-right: 2px solid #111; }
    .tp-text { display: flex; flex-direction: column; justify-content: center; padding: 48px 52px; background: #f0ede6; }

    .tab-panel[data-panel="0"] .tp-demo { background: #edf2fc; }
    .tab-panel[data-panel="1"] .tp-demo { background: #eef5ef; }
    .tab-panel[data-panel="2"] .tp-demo { background: #eeeafb; }
    .tab-panel[data-panel="3"] .tp-demo { background: #faf5f0; }
    .tab-panel[data-panel="4"] .tp-demo { background: #fefce6; }
    .tab-panel[data-panel="5"] .tp-demo { background: #f0ede6; }

    .tp-num  { font-family: 'Space Mono', monospace; font-size: 4rem; font-weight: 700; line-height: 1; margin-bottom: 16px; display: block; color: #ddd8cf; letter-spacing: -.02em; }
    .tp-name { font-weight: 800; font-size: 20px; line-height: 1.15; margin-bottom: 12px; text-transform: uppercase; letter-spacing: .03em; color: #111; }
    .tp-desc { font-size: 14px; line-height: 1.75; margin-bottom: 20px; max-width: 280px; color: #666; }
    .tp-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 28px; }
    .tp-tag  { font-family: 'Space Mono', monospace; font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: .07em; padding: 4px 10px; border: 1.5px solid #bbb; color: #555; background: white; }
    .tp-cta  { display: inline-flex; align-items: center; gap: 8px; background: #f5e642; color: #111; font-family: 'Space Mono', monospace; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; padding: 16px 28px; text-decoration: none; transition: background .15s; width: fit-content; border: 2px solid #111; }
    .tp-cta:hover { background: #d4c30a; }
    .tp-price { font-family: 'Space Mono', monospace; font-size: 26px; font-weight: 700; color: #111; line-height: 1; margin-bottom: 20px; display: flex; flex-direction: column; gap: 5px; }
    .tp-price-note { font-size: 9px; color: #999; font-weight: 400; text-transform: uppercase; letter-spacing: .08em; }
    .tp-for { font-size: 12px; color: #777; line-height: 1.6; margin-bottom: 16px; }

    .tp-demo .wc { max-width: 360px; width: 100%; }

    @media (min-width: 769px) {
      .mobile-carousel { display: none; }
    }
    @media (max-width: 768px) {
      .tab-nav, .tab-panel, .tab-panel.active { display: none !important; }
      .mobile-carousel { display: block; }

      .mc-info { padding: 28px 24px 22px; background: #f0ede6; border-bottom: 2px solid #111; min-height: 168px; }
      .mc-num  { font-family: 'Space Mono', monospace; font-size: 2.5rem; font-weight: 700; color: #ddd8cf; line-height: 1; display: block; margin-bottom: 8px; }
      .mc-name { font-weight: 800; font-size: 18px; text-transform: uppercase; letter-spacing: .03em; color: #111; margin-bottom: 10px; }
      .mc-desc { font-size: 13px; line-height: 1.7; color: #666; margin-bottom: 14px; }
      .mc-tags { display: flex; flex-wrap: wrap; gap: 5px; }
      .mc-tag  { font-family: 'Space Mono', monospace; font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: .07em; padding: 3px 9px; border: 1.5px solid #bbb; color: #555; background: white; }

      .mc-wrap  { overflow: hidden; background: #e8e4dc; padding: 28px 0; position: relative; }
      .mc-track { display: flex; gap: 16px; padding: 0 44px; transition: transform 0.38s cubic-bezier(0.25,0.46,0.45,0.94); will-change: transform; }
      .mc-slide { flex-shrink: 0; width: calc(100vw - 88px); }
      .mc-slide .wc { width: 100%; max-width: 100%; }

      .mc-footer { display: flex; justify-content: center; align-items: center; padding: 12px 24px; background: #111; gap: 8px; }
      .mc-btn { position: absolute; top: 50%; transform: translateY(-50%); z-index: 10; width: 40px; height: 60px; background: rgba(10,10,10,0.52); backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px); border: 1.5px solid rgba(245,230,66,0.45); color: #f5e642; font-size: 17px; cursor: pointer; display: flex; align-items: center; justify-content: center; font-weight: 700; transition: background .15s, border-color .15s; }
      .mc-btn-prev { left: 6px; border-radius: 0 4px 4px 0; }
      .mc-btn-next { right: 6px; border-radius: 4px 0 0 4px; }
      .mc-btn:not(:disabled):active { background: rgba(245,230,66,0.88); color: #111; border-color: #f5e642; }
      .mc-btn:disabled { opacity: 0; pointer-events: none; }
      .mc-dots { display: flex; gap: 8px; align-items: center; }
      .mc-dot  { width: 7px; height: 7px; border-radius: 50%; background: rgba(255,255,255,.22); border: none; padding: 0; cursor: pointer; transition: all .25s ease; }
      .mc-dot.active { background: #f5e642; width: 24px; border-radius: 3.5px; }
    }

    .wc {
      border-radius: 16px;
      overflow: hidden;
      border: 2px solid #111111;
      box-shadow: 4px 4px 0px #111111;
      font-family: 'Space Grotesk', sans-serif;
      background: white;
      display: flex;
      flex-direction: column;
      height: 480px;
      animation: wcIn 0.5s ease both;
    }
    @keyframes wcIn { from{opacity:0;transform:translateY(16px)} to{opacity:1;transform:translateY(0)} }
    .wc:nth-child(1){animation-delay:.05s}
    .wc:nth-child(2){animation-delay:.12s}
    .wc:nth-child(3){animation-delay:.18s}
    .wc:nth-child(4){animation-delay:.24s}
    .wc:nth-child(5){animation-delay:.30s}
    .wc:nth-child(6){animation-delay:.36s}

    .wc-header { padding: 16px 20px; flex-shrink: 0; }
    .wc-body   { padding: 16px 20px; flex: 1; overflow-y: auto; }
    .wc-badge  { display: inline-block; font-family: 'Space Mono', monospace; font-size: 9px; font-weight: 700; padding: 3px 10px; border-radius: 20px; text-transform: uppercase; letter-spacing: .08em; margin-bottom: 6px; }
    .wc-title  { font-weight: 700; font-size: 14px; }
    .wc-lbl    { font-family: 'Space Mono', monospace; font-size: 9px; text-transform: uppercase; letter-spacing: .1em; color: #94a3b8; display: block; margin: 10px 0 5px; }
    .wc-lbl:first-child { margin-top: 0; }
    .wc-inp    { width: 100%; border: 1.5px solid #e2e8f0; border-radius: 8px; font-size: 13px; padding: 8px 11px; outline: none; box-sizing: border-box; font-family: 'Space Grotesk', sans-serif; transition: border-color .2s; color: #1e293b; background: white; }
    .wc-result { border-radius: 10px; padding: 12px; text-align: center; margin: 10px 0; }
    .wc-rval   { font-family: 'Space Mono', monospace; font-weight: 700; font-size: 22px; }
    .wc-rlbl   { font-size: 9px; text-transform: uppercase; letter-spacing: .1em; margin-top: 3px; opacity: .65; }
    .wc-btn    { width: 100%; border: none; border-radius: 8px; font-weight: 700; font-size: 12px; padding: 11px; cursor: pointer; transition: opacity .15s; font-family: 'Space Grotesk', sans-serif; }
    .wc-btn:hover { opacity: .85; }

    /* 01 MORTGAGE */
    .wc-01 .wc-header { background: #e8edf5; }
    .wc-01 .wc-badge  { background: #c7d4e8; color: #2d4a7a; }
    .wc-01 .wc-title  { color: #2d4a7a; }
    .wc-01 .wc-result { background: #e8edf5; }
    .wc-01 .wc-rval   { color: #2d4a7a; }
    .wc-01 .wc-rlbl   { color: #5a7ab0; }
    .m-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; margin-top: 2px; }
    .m-stat  { background: #f4f7fc; border-radius: 8px; padding: 8px 10px; }
    .m-sv    { font-family: 'Space Mono', monospace; font-weight: 700; font-size: 11px; color: #2d4a7a; }
    .m-sl    { font-size: 9px; text-transform: uppercase; letter-spacing: .07em; color: #8aaad4; margin-top: 2px; }

    /* 02 BOOKING */
    .wc-02 .wc-header { background: #e8f0e9; display: flex; align-items: center; justify-content: space-between; }
    .wc-02 .wc-badge  { background: #c8dfca; color: #2d5e34; margin-bottom: 0; }
    .wc-02 .wc-title  { color: #2d5e34; }
        .bk-week-nav { display: flex; align-items: center; gap: 6px; margin: 6px 0 8px; }
    .bk-nav-btn  { width: 28px; height: 28px; border: 1.5px solid #e2e8f0; border-radius: 7px; background: white; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 14px; color: #475569; transition: all .15s; flex-shrink: 0; }
    .bk-nav-btn:hover { border-color: #4a8c52; color: #4a8c52; }
    .bk-week-lbl { font-family: 'Space Mono', monospace; font-size: 10px; color: #64748b; text-align: center; flex: 1; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; }
    .bk-cal  { display: grid; grid-template-columns: repeat(7,1fr); gap: 3px; margin-bottom: 8px; }
    .bk-dhdr { font-family: 'Space Mono', monospace; font-size: 8px; text-align: center; color: #94a3b8; padding: 2px 0; text-transform: uppercase; }
    .bk-d    { border-radius: 7px; padding: 5px 2px; text-align: center; cursor: pointer; transition: all .15s; border: 1.5px solid transparent; background: white; }
    .bk-d:hover { border-color: #c8dfca; background: #f0f7f1; }
    .bk-d.sel { background: #4a8c52; border-color: #4a8c52; }
    .bk-d.off { opacity: .3; cursor: not-allowed; }
    .bk-d-num  { font-weight: 700; font-size: 12px; color: #1e293b; display: block; }
    .bk-d.sel .bk-d-num { color: white; }
    .bk-d.off .bk-d-num { color: #94a3b8; }
    .bk-times { display: flex; flex-wrap: wrap; gap: 4px; margin-bottom: 8px; }
    .bk-t    { border: 1.5px solid #c8dfca; border-radius: 6px; background: white; font-family: 'Space Mono', monospace; font-size: 10px; font-weight: 700; padding: 4px 8px; cursor: pointer; color: #4a8c52; transition: all .15s; }
    .bk-t:hover,.bk-t.sel { background: #4a8c52; color: white; border-color: #4a8c52; }
    .bk-t.busy { color: #c8dfca; border-color: #f1f5f9; cursor: not-allowed; background: #fafafa; }
    .bk-btn  { width: 100%; background: #4a8c52; color: white; border: none; border-radius: 8px; font-weight: 700; font-size: 12px; padding: 10px; cursor: pointer; transition: background .15s; margin-top: 4px; }
    .bk-btn:hover { background: #3a7a42; }
    .bk-success { background: #f0f7f1; border: 1.5px solid #c8dfca; border-radius: 8px; padding: 12px; text-align: center; font-family: 'Space Mono', monospace; font-size: 9px; color: #2d5e34; text-transform: uppercase; letter-spacing: .07em; margin-top: 6px; }

    /* 03 CHATBOT */
    .wc-03 { border-radius: 20px !important; display: flex; flex-direction: column; }
    .wc-03 .wc-header { background: #ebe8f5; display: flex; align-items: center; gap: 10px; padding: 14px 18px; flex-shrink: 0; }
    .chat-av  { width: 34px; height: 34px; border-radius: 50%; background: #c9c2e8; display: flex; align-items: center; justify-content: center; font-size: 16px; flex-shrink: 0; }
    .chat-nm  { font-weight: 700; font-size: 13px; color: #4a3d8c; }
    .chat-st  { font-size: 10px; color: #8a7fc4; display: flex; align-items: center; gap: 3px; }
    .chat-dot { width: 5px; height: 5px; background: #7bc47f; border-radius: 50%; display: inline-block; }
    .chat-msgs { background: #f7f6fc; padding: 10px 14px; display: flex; flex-direction: column; gap: 6px; flex: 1; overflow-y: auto; }
    .msg-ai   { background: white; border: 1px solid #e2ddf5; border-radius: 10px 10px 10px 3px; padding: 7px 10px; font-size: 11px; color: #4a3d8c; max-width: 88%; align-self: flex-start; line-height: 1.5; }
    .msg-me   { background: #7a6ec4; border-radius: 10px 10px 3px 10px; padding: 7px 10px; font-size: 11px; color: white; max-width: 88%; align-self: flex-end; line-height: 1.5; }
    .msg-typing { display: flex; gap: 3px; align-items: center; padding: 7px 10px; background: white; border: 1px solid #e2ddf5; border-radius: 10px 10px 10px 3px; width: fit-content; }
    .msg-typing span { width: 5px; height: 5px; background: #c9c2e8; border-radius: 50%; animation: td .8s infinite; }
    .msg-typing span:nth-child(2){animation-delay:.15s}
    .msg-typing span:nth-child(3){animation-delay:.30s}
    @keyframes td{0%,80%,100%{transform:scale(1);opacity:.4}40%{transform:scale(1.3);opacity:1}}
    .chat-quick { display: flex; flex-wrap: wrap; gap: 4px; padding: 8px 14px; background: #f7f6fc; border-top: 1px solid #ede9f7; flex-shrink: 0; }
    .chat-qb  { border: 1px solid #ddd9f0; border-radius: 20px; background: white; font-size: 9px; color: #7a6ec4; padding: 3px 9px; cursor: pointer; font-weight: 600; transition: all .15s; }
    .chat-qb:hover { background: #7a6ec4; color: white; border-color: #7a6ec4; }
    .chat-row { display: flex; border-top: 1px solid #ede9f7; background: white; border-radius: 0 0 18px 18px; flex-shrink: 0; overflow: hidden; }
    .chat-row input { flex: 1; border: none; padding: 10px 12px; font-size: 12px; outline: none; color: #334155; font-family: 'Space Grotesk', sans-serif; }
    .chat-row button { background: #7a6ec4; color: white; border: none; padding: 10px 14px; cursor: pointer; font-size: 13px; transition: background .15s; border-radius: 0 0 18px 0; }
    .chat-row button:hover { background: #6a5eb4; }

    /* 04 BMI */
    .wc-04 .wc-header { background: #f2ebe5; }
    .wc-04 .wc-badge  { background: #e4d0c0; color: #7a4a2d; }
    .wc-04 .wc-title  { color: #7a4a2d; }
    .wc-04 .wc-result { background: #f2ebe5; }
    .wc-04 .wc-rlbl   { color: #b07a5a; }
    .bmi-track  { height: 8px; background: #edddd4; border-radius: 4px; margin: 8px 0 4px; overflow: hidden; }
    .bmi-fill   { height: 100%; border-radius: 4px; transition: width .5s, background .4s; width: 52%; background: #c47a52; }
    .bmi-marks  { display: flex; justify-content: space-between; font-family: 'Space Mono', monospace; font-size: 8px; color: #c0956e; margin-bottom: 8px; }
    .bmi-ideal  { font-family: 'Space Mono', monospace; font-size: 10px; color: #b07a5a; margin-bottom: 6px; }
    .bmi-advice { background: #fdf7f3; border-radius: 8px; padding: 9px 11px; font-size: 11px; color: #9a6040; line-height: 1.5; }

    /* 05 UTILITY */
    .wc-05 { background: white; }
