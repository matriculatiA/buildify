    .wc-06 select { width: 100%; border: 1.5px solid #e2e8f0; border-radius: 8px; color: #1e293b; font-weight: 600; font-size: 13px; padding: 8px 11px; outline: none; box-sizing: border-box; cursor: pointer; font-family: 'Space Grotesk', sans-serif; margin-bottom: 0; }
