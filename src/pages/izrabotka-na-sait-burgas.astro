---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icons.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "buildify.bg — Изработка на сайт Бургас",
  "url": "https://buildify.bg",
  "areaServed": { "@type": "City", "name": "Бургас" },
  "description": "Изработка на уебсайт в Бургас. Custom сайтове, онлайн резервации, AI ботове. Фиксирана цена, без абонамент.",
  "priceRange": "350€ - 1200€"
};
---

<BaseLayout
  title="Изработка на сайт Бургас | buildify.bg — от 350€"
  description="Изработка на уебсайт в Бургас. Custom сайтове за ресторанти, зъболекари, адвокати, хотели. Фиксирана цена от 350€, без абонамент. Вижте demo сайтове."
  schema={schema}
>

  <!-- HERO -->
  <section class="bg-ink text-white border-b-2 border-ink grid md:grid-cols-2 min-h-[55vh]">
    <div class="px-8 md:px-14 py-16 flex flex-col justify-between">
      <span class="font-mono text-xs text-white/40 uppercase tracking-widest">buildify.bg / Бургас</span>
      <div>
        <h1 class="font-bold text-white leading-tight tracking-tightest mb-5" style="font-size:clamp(2.2rem,5.5vw,4rem)">
          Изработка на<br/>сайт в Бургас.<br/>
          <mark class="bg-yellow text-ink px-2 not-italic">Без излишества.</mark>
        </h1>
        <p class="text-white/40 text-base leading-relaxed max-w-sm">
          Custom уебсайт за вашия бизнес в Бургас. Фиксирана цена, ясен срок, без абонамент.
        </p>
      </div>
      <a href="/kontakt" class="inline-flex items-center gap-3 bg-yellow text-ink font-bold text-sm px-7 py-4 uppercase tracking-wide hover:bg-yellow-dark transition-colors w-fit mt-8">
        Поискайте безплатна оферта →
      </a>
    </div>
    <div class="bg-paper border-t-2 md:border-t-0 md:border-l-2 border-white/10 px-8 md:px-14 py-16 flex flex-col justify-center gap-6">
      {[
        { num: "350€",   label: "Стартова цена за сайт",       sub: "без скрити такси" },
        { num: "7-14",   label: "Работни дни до пускане",       sub: "фиксиран срок" },
        { num: "0€",     label: "Месечен абонамент",            sub: "еднократно плащане" },
        { num: "100%",   label: "Custom — не шаблон",           sub: "направен за вашия бизнес" },
      ].map(s => (
        <div class="flex items-center gap-5">
          <span class="font-mono font-bold text-yellow text-2xl shrink-0 w-16">{s.num}</span>
          <div>
            <div class="font-bold text-white text-sm">{s.label}</div>
            <div class="font-mono text-xs text-white/30 mt-0.5">{s.sub}</div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- КОГО ПРАВИМ -->
  <section class="bg-cream border-b-2 border-ink">
    <div class="border-b-2 border-ink px-8 py-5">
      <span class="font-mono text-xs uppercase tracking-widest text-muted font-bold">01 · За кой тип бизнес правим сайтове в Бургас</span>
    </div>
    <div class="grid md:grid-cols-3 divide-y-2 md:divide-y-0 divide-ink">
      {[
        { icon: "web",       title: "Ресторанти и заведения",   desc: "Меню, онлайн резервации, работно време, галерия. Клиентите ви намират в Google преди да са тръгнали от вкъщи.", link: "/demo/restoran", linkText: "Виж demo →" },
        { icon: "bot",       title: "Лекарски кабинети",        desc: "Онлайн записване за час 24/7, списък с услуги, застраховки, локация. Без телефонни обаждания в 9 вечерта.", link: "/demo/dentalen-kabinet", linkText: "Виж demo →" },
        { icon: "seo",       title: "Адвокати и консултанти",   desc: "Практики, екип, публикации, контакт форма. Сериозен сайт, който изгражда доверие преди първата среща.", link: "/demo/advokat", linkText: "Виж demo →" },
        { icon: "plugin",    title: "Хотели и стаи под наем",   desc: "Галерия, стаи, наличност, резервации. Директни резервации без комисионна към Booking.com.", link: "/kontakt", linkText: "Поискай оферта →" },
        { icon: "star",      title: "Счетоводители и одитори",  desc: "Услуги, екип, блог за данъчни срокове. Клиентите ви намират когато търсят счетоводител в Бургас.", link: "/kontakt", linkText: "Поискай оферта →" },
        { icon: "form-broken", title: "Всеки друг бизнес",    desc: "Фризьорски салон, автосервиз, магазин, фитнес — ако имате клиенти, трябва ви сайт, който работи.", link: "/kontakt", linkText: "Поискай оферта →" },
      ].map((item, i) => (
        <div class={`p-8 border-b-2 md:border-b-0 border-ink ${i % 3 !== 2 ? 'md:border-r-2' : ''} ${i >= 3 ? 'border-b-0' : ''}`}>
          <div class="mb-4"><Icon name={item.icon} size={28} /></div>
          <h3 class="font-bold text-sm uppercase tracking-tight text-ink mb-2">{item.title}</h3>
          <p class="text-muted text-sm leading-relaxed mb-4">{item.desc}</p>
          <a href={item.link} class="font-mono text-xs font-bold text-ink border-b border-ink/30 hover:border-ink transition-colors">{item.linkText}</a>
        </div>
      ))}
    </div>
  </section>

  <!-- ЗАЩО BUILDIFY -->
  <section class="border-b-2 border-ink">
    <div class="border-b-2 border-ink px-8 py-5">
      <span class="font-mono text-xs uppercase tracking-widest text-muted font-bold">02 · Защо не обичайна агенция</span>
    </div>
    <div class="grid md:grid-cols-2 gap-0 divide-y-2 md:divide-y-0 md:divide-x-2 divide-ink">
      <div class="p-8 md:p-12 bg-ink text-white">
        <h2 class="font-bold text-white text-xl tracking-tight mb-6 uppercase">Обичайна уеб агенция</h2>
        <div class="space-y-3">
          {[
            "Оферта след 3-5 работни дни",
            "Абонамент от 30-80€/месец за поддръжка",
            "Шаблон с малко промени",
            "Не разбирате какво плащате",
            "Срокът се мести многократно",
          ].map(item => (
            <div class="flex gap-3 items-start">
              <span class="text-red-400 font-mono text-sm shrink-0 mt-0.5">✕</span>
              <span class="text-white/60 text-sm">{item}</span>
            </div>
          ))}
        </div>
      </div>
      <div class="p-8 md:p-12 bg-yellow">
        <h2 class="font-bold text-ink text-xl tracking-tight mb-6 uppercase">buildify.bg</h2>
        <div class="space-y-3">
          {[
            "Оферта до 24 часа",
            "Без абонамент — еднократна цена",
            "Custom дизайн за вашия бизнес",
            "Фиксирана цена преди да започнем",
            "Фиксиран срок — 7-14 работни дни",
          ].map(item => (
            <div class="flex gap-3 items-start">
              <span class="text-ink font-mono text-sm shrink-0 mt-0.5">✓</span>
              <span class="text-ink/80 text-sm font-medium">{item}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ЦЕНИ -->
  <section class="bg-cream border-b-2 border-ink">
    <div class="border-b-2 border-ink px-8 py-5">
      <span class="font-mono text-xs uppercase tracking-widest text-muted font-bold">03 · Цени за изработка на сайт в Бургас</span>
    </div>
    <div class="grid md:grid-cols-3 divide-y-2 md:divide-y-0 md:divide-x-2 divide-ink">
      {[
        {
          name: "Starter",
          price: "350€",
          sub: "еднократно",
          items: ["До 5 секции", "Контактна форма", "Google Maps", "Мобилна версия", "SEO основи"],
          for: "Визитка, малък бизнес",
        },
        {
          name: "Business",
          price: "650€",
          sub: "еднократно",
          items: ["До 10 секции", "Блог / новини", "Онлайн резервации", "Галерия", "Google Analytics", "SEO оптимизация"],
          for: "Ресторант, кабинет, хотел",
          highlight: true,
        },
        {
          name: "Professional",
          price: "1 200€+",
          sub: "еднократно",
          items: ["Неограничени секции", "AI чатбот", "API интеграции", "Онлайн плащания", "Admin панел"],
          for: "По-сложни бизнес нужди",
        },
      ].map(tier => (
        <div class={`p-8 ${tier.highlight ? 'bg-ink' : ''}`}>
          <div class={`font-mono text-xs font-bold uppercase tracking-widest mb-2 ${tier.highlight ? 'text-yellow' : 'text-muted'}`}>{tier.name}</div>
          <div class={`font-mono font-bold text-3xl mb-0.5 ${tier.highlight ? 'text-yellow' : 'text-ink'}`}>{tier.price}</div>
          <div class={`font-mono text-xs mb-6 ${tier.highlight ? 'text-white/30' : 'text-muted'}`}>{tier.sub}</div>
          <ul class="space-y-2 mb-6">
            {tier.items.map(item => (
              <li class={`text-sm flex gap-2 ${tier.highlight ? 'text-white/70' : 'text-ink/70'}`}>
                <span class={`shrink-0 font-mono ${tier.highlight ? 'text-yellow' : 'text-ink'}`}>›</span>{item}
              </li>
            ))}
          </ul>
          <div class={`font-mono text-xs ${tier.highlight ? 'text-white/30' : 'text-muted'}`}>Подходящо за: {tier.for}</div>
        </div>
      ))}
    </div>
    <div class="border-t-2 border-ink px-8 py-6 flex flex-col md:flex-row md:items-center gap-4">
      <a href="/kontakt" class="inline-flex items-center gap-3 bg-ink text-yellow font-bold text-sm px-7 py-4 uppercase tracking-wide hover:bg-yellow hover:text-ink transition-colors w-fit">
        Поискайте безплатна оферта →
      </a>
      <span class="font-mono text-xs text-muted">Отговаряме до 24 часа · Без задължения</span>
    </div>
  </section>

  <!-- КАК РАБОТИМ -->
  <section class="border-b-2 border-ink">
    <div class="border-b-2 border-ink px-8 py-5">
      <span class="font-mono text-xs uppercase tracking-widest text-muted font-bold">04 · Как протича работата</span>
    </div>
    <div class="grid md:grid-cols-4 divide-y-2 md:divide-y-0 md:divide-x-2 divide-ink">
      {[
        { num: "01", title: "Описвате нуждата",      desc: "Попълвате кратка форма или се обаждате. Без технически знания — просто казвате какво правите." },
        { num: "02", title: "Получавате оферта",     desc: "До 24 часа — фиксирана цена и срок. Без изненади по-нататък." },
        { num: "03", title: "Разработваме",          desc: "7-14 работни дни. Показваме ви прогрес и вземаме обратна връзка." },
        { num: "04", title: "Пускаме сайта",         desc: "Тестваме, оптимизираме, пускаме. Обясняваме как да го управлявате." },
      ].map(step => (
        <div class="p-8">
          <span class="font-mono font-bold text-ink/15 text-4xl block mb-4">{step.num}</span>
          <h3 class="font-bold text-sm uppercase tracking-tight text-ink mb-2">{step.title}</h3>
          <p class="text-muted text-sm leading-relaxed">{step.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA ФИНАЛ -->
  <section class="bg-ink">
    <div class="max-w-3xl mx-auto px-8 py-16 text-center">
      <span class="font-mono text-xs text-yellow uppercase tracking-widest block mb-4">buildify.bg · Бургас</span>
      <h2 class="font-bold text-white text-3xl tracking-tight mb-4">Готови да започнем?</h2>
      <p class="text-white/40 mb-8 max-w-md mx-auto">Опишете бизнеса си и ще ви изпратим оферта до 24 часа. Без задължения, без аванс преди одобрение.</p>
      <a href="/kontakt" class="inline-flex items-center gap-3 bg-yellow text-ink font-bold text-sm px-8 py-4 uppercase tracking-wide hover:bg-yellow-dark transition-colors">
        Безплатна оферта →
      </a>
    </div>
  </section>

</BaseLayout>
