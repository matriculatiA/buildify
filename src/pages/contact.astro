---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Контакти - Безплатна консултация | buildify.bg"
  description="Свържи се с buildify.bg за безплатна консултация. Отговаряме до 24 часа."
>

  <!-- Header -->
  <section class="grid md:grid-cols-2 border-b-2 border-ink min-h-[30vh]">
    <div class="bg-ink p-10 md:p-16 flex flex-col justify-between border-b-2 md:border-b-0 md:border-r-2 border-yellow/20">
      <span class="font-mono text-xs uppercase tracking-widest text-white/30">buildify.bg / контакт</span>
      <div>
        <h1 class="font-bold text-5xl md:text-6xl text-white uppercase tracking-tightest leading-tight mb-4">
          Да<br/><span class="text-yellow">поговорим.</span>
        </h1>
        <p class="text-white/40 text-base">Опиши накратко какво ти трябва. Отговаряме до 24 часа с конкретна цена.</p>
      </div>
    </div>
    <div class="bg-cream p-10 md:p-16 flex flex-col justify-center gap-6">
      {[
        'Конкретна цена и срок — не "зависи от обема"',
        'Отговор на въпроси без продаване',
        'Без договори при първи разговор',
        'Отговаряме до 24 часа в работен ден',
      ].map(item => (
        <div class="flex items-start gap-3 border-l-4 border-yellow pl-4 py-1">
          <span class="font-mono text-xs text-yellow shrink-0 mt-0.5">✓</span>
          <span class="text-sm font-semibold text-ink">{item}</span>
        </div>
      ))}
      <div class="border-t-2 border-ink pt-6 mt-2">
        <div class="font-mono text-xs uppercase tracking-widest text-muted mb-3">Или пиши директно</div>
        <a href="mailto:hello@buildify.bg" class="font-bold text-ink hover:text-yellow transition-colors text-base">hello@buildify.bg</a>
      </div>
    </div>
  </section>

  <!-- Form -->
  <section class="bg-cream border-b-2 border-ink p-10 md:p-16">
    <div class="max-w-2xl">

      <!-- Success message (hidden by default) -->
      <div id="form-success" style="display:none" class="bg-ink border-2 border-ink p-8 mb-6 text-center">
        <div class="font-mono text-xs text-yellow uppercase tracking-widest mb-3">✓ Съобщението е изпратено</div>
        <p class="text-white/60 text-sm">Ще се свържем с теб до 24 часа.</p>
      </div>

      <form id="contact-form" class="border-2 border-ink">
        <div class="grid md:grid-cols-2 divide-y-2 md:divide-y-0 md:divide-x-2 divide-ink border-b-2 border-ink">
          <div class="p-6 flex flex-col gap-2">
            <label class="font-mono text-xs font-bold uppercase tracking-widest text-muted">Твоето име *</label>
            <input
              type="text" name="name" required placeholder="Иван Иванов"
              class="bg-transparent font-semibold text-ink placeholder:text-ink/20 outline-none text-base"
            />
          </div>
          <div class="p-6 flex flex-col gap-2">
            <label class="font-mono text-xs font-bold uppercase tracking-widest text-muted">Имейл *</label>
            <input
              type="email" name="email" required placeholder="ivan@firma.bg"
              class="bg-transparent font-semibold text-ink placeholder:text-ink/20 outline-none text-base"
            />
          </div>
        </div>

        <div class="p-6 flex flex-col gap-2 border-b-2 border-ink">
          <label class="font-mono text-xs font-bold uppercase tracking-widest text-muted">Телефон (незадължително)</label>
          <input
            type="tel" name="phone" placeholder="+359 88 888 8888"
            class="bg-transparent font-semibold text-ink placeholder:text-ink/20 outline-none text-base"
          />
        </div>

        <!-- Custom select: Интересувам се от -->
        <div class="p-6 flex flex-col gap-2 border-b-2 border-ink">
          <label class="font-mono text-xs font-bold uppercase tracking-widest text-muted">Интересувам се от</label>
          <input type="hidden" name="service" id="val-service" />
          <div class="custom-select" data-target="val-service">
            <button type="button" class="cs-trigger" aria-haspopup="listbox">
              <span class="cs-label">Избери...</span>
              <span class="cs-arrow">↓</span>
            </button>
            <ul class="cs-list" role="listbox">
              <li role="option" data-value="">Избери...</li>
              <li role="option" data-value="Уебсайт">Уебсайт</li>
              <li role="option" data-value="Плъгин">Плъгин</li>
              <li role="option" data-value="AI бот">AI бот</li>
              <li role="option" data-value="Не знам още">Не знам още</li>
            </ul>
          </div>
        </div>

        <div class="grid md:grid-cols-2 divide-y-2 md:divide-y-0 md:divide-x-2 divide-ink border-b-2 border-ink">
          <!-- Custom select: Бюджет -->
          <div class="p-6 flex flex-col gap-2">
            <label class="font-mono text-xs font-bold uppercase tracking-widest text-muted">Бюджет (ориентировъчно)</label>
            <input type="hidden" name="budget" id="val-budget" />
            <div class="custom-select" data-target="val-budget">
              <button type="button" class="cs-trigger" aria-haspopup="listbox">
                <span class="cs-label">Не знам още</span>
                <span class="cs-arrow">↓</span>
              </button>
              <ul class="cs-list" role="listbox">
                <li role="option" data-value="">Не знам още</li>
                <li role="option" data-value="до 500€">до 500€</li>
                <li role="option" data-value="500€ – 1 000€">500€ – 1 000€</li>
                <li role="option" data-value="1 000€ – 3 000€">1 000€ – 3 000€</li>
                <li role="option" data-value="над 3 000€">над 3 000€</li>
              </ul>
            </div>
          </div>
          <!-- Custom select: Срок -->
          <div class="p-6 flex flex-col gap-2">
            <label class="font-mono text-xs font-bold uppercase tracking-widest text-muted">Срок</label>
            <input type="hidden" name="timeline" id="val-timeline" />
            <div class="custom-select" data-target="val-timeline">
              <button type="button" class="cs-trigger" aria-haspopup="listbox">
                <span class="cs-label">Без конкретен срок</span>
                <span class="cs-arrow">↓</span>
              </button>
              <ul class="cs-list" role="listbox">
                <li role="option" data-value="">Без конкретен срок</li>
                <li role="option" data-value="Колкото се може по-скоро">Колкото се може по-скоро</li>
                <li role="option" data-value="До 1 месец">До 1 месец</li>
                <li role="option" data-value="1 – 3 месеца">1 – 3 месеца</li>
                <li role="option" data-value="Само проучвам">Само проучвам</li>
              </ul>
            </div>
          </div>
        </div>

        <div class="p-6 flex flex-col gap-2 border-b-2 border-ink">
          <label class="font-mono text-xs font-bold uppercase tracking-widest text-muted">Съобщение</label>
          <textarea
            name="message" rows="4"
            placeholder="Разкажи накратко какво ти трябва..."
            class="bg-transparent font-semibold text-ink placeholder:text-ink/20 outline-none text-base resize-none"
          ></textarea>
        </div>

        <button
          type="submit"
          id="submit-btn"
          class="w-full bg-yellow text-ink font-bold uppercase tracking-wider py-5 text-sm hover:bg-yellow-dark transition-colors"
        >
          Изпрати запитване →
        </button>
      </form>

    </div>
  </section>

</BaseLayout>

<style>
  .custom-select { position: relative; }

  .cs-trigger {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: transparent;
    border: none;
    border-bottom: 2px solid #111;
    padding: 8px 0;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: #111;
    cursor: pointer;
    text-align: left;
    gap: 8px;
  }
  .cs-trigger:focus { outline: none; border-bottom-color: #f5e642; }

  .cs-arrow {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    color: #777;
    transition: transform 0.15s;
    flex-shrink: 0;
  }
  .custom-select.open .cs-arrow { transform: rotate(180deg); color: #f5e642; }

  .cs-list {
    display: none;
    position: absolute;
    top: calc(100% + 2px);
    left: -24px;
    right: -24px;
    background: #111;
    border: 2px solid #111;
    z-index: 50;
    list-style: none;
    margin: 0;
    padding: 4px 0;
  }
  .custom-select.open .cs-list { display: block; }

  .cs-list li {
    padding: 10px 20px;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.875rem;
    font-weight: 600;
    color: rgba(255,255,255,0.55);
    cursor: pointer;
    border-left: 3px solid transparent;
    transition: all 0.1s;
  }
  .cs-list li:hover {
    color: #f5e642;
    border-left-color: #f5e642;
    background: rgba(245,230,66,0.07);
  }
  .cs-list li.selected {
    color: #f5e642;
    border-left-color: #f5e642;
  }
  .cs-list li[data-value=""] { color: rgba(255,255,255,0.25); }
</style>

<script>
  // Custom selects
  document.querySelectorAll<HTMLElement>('.custom-select').forEach(select => {
    const trigger = select.querySelector<HTMLButtonElement>('.cs-trigger')!;
    const label   = select.querySelector<HTMLElement>('.cs-label')!;
    const list    = select.querySelector<HTMLElement>('.cs-list')!;
    const hidden  = document.getElementById(select.dataset.target!) as HTMLInputElement;

    trigger.addEventListener('click', e => {
      e.stopPropagation();
      const isOpen = select.classList.contains('open');
      document.querySelectorAll('.custom-select.open').forEach(s => s.classList.remove('open'));
      if (!isOpen) select.classList.add('open');
    });

    list.querySelectorAll<HTMLElement>('li').forEach(item => {
      item.addEventListener('click', () => {
        label.textContent = item.textContent;
        hidden.value = item.dataset.value ?? '';
        list.querySelectorAll('li').forEach(li => li.classList.remove('selected'));
        if (item.dataset.value) item.classList.add('selected');
        select.classList.remove('open');
      });
    });
  });

  document.addEventListener('click', () => {
    document.querySelectorAll('.custom-select.open').forEach(s => s.classList.remove('open'));
  });

  // Form submit
  document.getElementById('contact-form')?.addEventListener('submit', async function(e) {
    e.preventDefault();
    const btn = document.getElementById('submit-btn') as HTMLButtonElement;
    btn.textContent = 'Изпраща...';
    btn.disabled = true;

    const data = new FormData(this as HTMLFormElement);
    try {
      const res = await fetch('https://formspree.io/f/xjgpvgle', {
        method: 'POST',
        body: data,
        headers: { 'Accept': 'application/json' }
      });
      if (res.ok) {
        (document.getElementById('contact-form') as HTMLElement).style.display = 'none';
        (document.getElementById('form-success') as HTMLElement).style.display = 'block';
      } else {
        btn.textContent = 'Грешка — опитай отново';
        btn.disabled = false;
      }
    } catch {
      btn.textContent = 'Грешка — опитай отново';
      btn.disabled = false;
    }
  });
</script>
