---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icons.astro';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Изработка на уебсайтове",
    "provider": { "@type": "Organization", "name": "buildify.bg", "url": "https://buildify.bg" },
    "description": "Изработка на бизнес уебсайтове и landing pages оптимизирани за Google. SEO в структурата, Core Web Vitals зелено, прозрачни цени. Обслужваме Бургас и цяла България.",
    "areaServed": ["Бургас", "България"],
    "offers": [
      { "@type": "Offer", "name": "Landing page",     "price": "350",  "priceCurrency": "EUR" },
      { "@type": "Offer", "name": "Бизнес сайт",      "price": "750",  "priceCurrency": "EUR" },
      { "@type": "Offer", "name": "Корпоративен сайт","price": "1800", "priceCurrency": "EUR" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Колко струва изработката на уебсайт в България?",
        "acceptedAnswer": { "@type": "Answer", "text": "Цените започват от 350€ за landing page, 750€ за бизнес сайт до 8 страници и от 1800€ за корпоративен проект. В цената са включени дизайн, разработка и SEO оптимизация. Хостингът е безплатен — деплойваме на Cloudflare Pages." }
      },
      {
        "@type": "Question",
        "name": "Колко отнема изработката на уебсайт?",
        "acceptedAnswer": { "@type": "Answer", "text": "Landing page — 5-7 работни дни. Бизнес сайт — 2-3 седмици. Корпоративен проект — 4-8 седмици в зависимост от обема." }
      },
      {
        "@type": "Question",
        "name": "WordPress или custom сайт — кое е по-добро за бизнес?",
        "acceptedAnswer": { "@type": "Answer", "text": "За бизнес сайт с цел продажби — custom сайт с Astro е по-добър избор: без плъгини, без месечни абонаменти, максимална скорост и Core Web Vitals зелено. WordPress е подходящ за масови блогове с много автори. Ако вашият случай изисква WordPress — казваме го честно." }
      },
      {
        "@type": "Question",
        "name": "Нужен ли ми е хостинг отделно?",
        "acceptedAnswer": { "@type": "Answer", "text": "Не. Деплойваме безплатно на Cloudflare Pages. Плащате само за домейна (~10€/год.)." }
      },
      {
        "@type": "Question",
        "name": "Правите ли SEO оптимизация?",
        "acceptedAnswer": { "@type": "Answer", "text": "Да — SEO е вградено в кода, не добавено след: Schema markup, sitemap, правилни мета тагове, структурирани заглавия (H1/H2/H3), оптимизирани изображения, бърза скорост. Правим и основно проучване на ключови думи за вашия бранш." }
      },
      {
        "@type": "Question",
        "name": "Работите ли само в Бургас?",
        "acceptedAnswer": { "@type": "Answer", "text": "Не — работим дистанционно с клиенти от цяла България. Базирани сме в Бургас, но процесът е изцяло онлайн: консултация по видео, дизайн в споделен файл, комуникация в чат." }
      }
    ]
  }
];

const packages = [
  {
    name: "Landing page", price: "от 350€", for: "Промоция / един продукт / услуга",
    features: ["До 5 секции", "Контактна форма", "Mobile-first дизайн", "SEO оптимизация", "Безплатен хостинг (Cloudflare)", "Готов до 7 дни"],
    featured: false,
  },
  {
    name: "Бизнес сайт", price: "от 750€", for: "Малък и среден бизнес",
    features: ["До 8 страници", "Блог / новини", "Google Analytics 4", "Schema markup", "Core Web Vitals зелено", "Google Search Console", "Готов до 3 седмици"],
    featured: true,
  },
  {
    name: "Корпоративен", price: "от 1 800€", for: "По-сложни проекти",
    features: ["Неограничени страници", "Многоезичност", "CMS за редакция", "E-commerce / резервации", "Персонализирани интеграции", "Приоритетна поддръжка"],
    featured: false,
  },
];

const industries = [
  { code: "REST", name: "Ресторант / Заведение", desc: "Онлайн меню, резервации, работно време, отзиви. Клиентите намират заведението ви в Google Maps преди да излязат от вкъщи.", href: "/demo/restoran", demo: true },
  { code: "MED",  name: "Дентален кабинет / Лекар", desc: "Онлайн запис на час, услуги с цени, екип. Нови пациенти от Google всеки месец без да плащате реклама.", href: "/demo/dentalen-kabinet", demo: true },
  { code: "LAW",  name: "Адвокат / Юридически услуги", desc: "Практики, екип, форма за консултация. Позиция в Google по специализация и локация — преди клиентът да потърси конкурент.", href: "/demo/advokat", demo: true },
  { code: "SPA",  name: "Козметичен салон / Фризьор", desc: "Галерия с процедури, ценоразпис, онлайн запис. Работи вместо вас 24/7 и пълни календара автоматично.", href: null, demo: false },
  { code: "HTL",  name: "Хотел / Стаи под наем", desc: "Директни резервации без 15% комисионна на Booking.com. Снимки, удобства, наличност — всичко на вашия домейн.", href: null, demo: false },
  { code: "CON",  name: "Строителна фирма / Ремонти", desc: "Портфолио от реализирани проекти, услуги, контакти. Доверие и референции преди първата среща с клиента.", href: null, demo: false },
  { code: "ACC",  name: "Счетоводител / Консултант", desc: "Услуги, цени, опит. Позиция в Google по локация и специализация — без да разчитате само на препоръки.", href: null, demo: false },
  { code: "SHOP", name: "Онлайн магазин", desc: "Малък e-commerce с плащане с карта, управление на наличности и автоматични имейл потвърждения. Без Shopify абонамент.", href: null, demo: false },
];

const steps = [
  {
    n: "01", title: "Безплатна консултация",
    desc: "30-минутен разговор за вашия бизнес, целевата аудитория и конкурентите. Получавате реалистична оферта и времева рамка — без обвързване.",
    detail: "Видео / телефон / лично в Бургас"
  },
  {
    n: "02", title: "Структура и дизайн",
    desc: "Изграждаме структурата на сайта (wireframe), цветова схема, типография. При нужда — помагаме с текстовете. Ревизии до одобрение.",
    detail: "Включен в пакета"
  },
  {
    n: "03", title: "Разработка и SEO",
    desc: "Кодираме с Astro за максимална скорост. SEO е вграден в кода от нулата: Schema markup, мета тагове, H1/H2 структура, оптимизирани изображения.",
    detail: "Core Web Vitals зелено гарантирано"
  },
  {
    n: "04", title: "Публикуване и предаване",
    desc: "Деплойваме на Cloudflare Pages (безплатно). Верифицираме домейна в Google Search Console. Обучаваме ви как да следите трафика.",
    detail: "Cloudflare CDN + SSL без доп. разходи"
  },
];
---

<BaseLayout
  title="Изработка на уебсайт за бизнес | buildify.bg — Бургас и България"
  description="Изработка на бизнес уебсайтове оптимизирани за Google. SEO в кода, Core Web Vitals зелено, безплатен хостинг. Ресторанти, кабинети, адвокати, магазини. От 350€."
  schema={schema}
>

  <!-- Hero split -->
  <section class="border-b-2 border-ink grid md:grid-cols-2 min-h-[60vh]">
    <div class="bg-ink text-white px-8 md:px-14 py-16 flex flex-col justify-between">
      <span class="font-mono text-xs text-white/45 uppercase tracking-widest">buildify.bg / Уебсайтове</span>
      <div>
        <h1 class="font-bold text-white leading-tight tracking-tightest mb-5" style="font-size:clamp(2.5rem,6vw,4.5rem)">
          Сайт, който<br/>
          <span class="bg-yellow text-ink px-2">продава.</span><br/>
          Не само изглежда добре.
        </h1>
        <p class="text-white/40 text-base leading-relaxed max-w-sm">
          Изработваме бизнес уебсайтове, оптимизирани за Google от нулата — бързи, мобилни, с вграден SEO. За Бургас и цяла България.
        </p>
      </div>
      <div class="flex flex-col sm:flex-row gap-3">
        <a href="/contact" class="inline-flex items-center gap-3 bg-yellow text-ink font-bold text-sm px-7 py-4 uppercase tracking-wide hover:bg-yellow-dark transition-colors">
          Безплатна консултация →
        </a>
        <a href="#paketi" class="inline-flex items-center gap-3 border-2 border-white/20 text-white/60 font-semibold text-sm px-7 py-4 uppercase tracking-wide hover:border-yellow hover:text-yellow transition-colors">
          Виж пакетите ↓
        </a>
      </div>
    </div>
    <div class="bg-cream px-8 md:px-14 py-16 flex flex-col justify-center gap-6 border-t-2 md:border-t-0 md:border-l-2 border-ink">
      {[
        { icon: "speed",         title: "БЪРЗИНА",                   desc: "Под 2 секунди зареждане. Core Web Vitals зелено. Google класира бързите сайтове по-високо." },
        { icon: "seo",           title: "SEO В СТРУКТУРАТА",         desc: "Schema markup, sitemap, мета тагове, H1/H2 — наредено преди публикуване, не добавено след." },
        { icon: "mobile-broken", title: "MOBILE-FIRST",              desc: "70%+ от трафика е мобилен. Правим сайта за телефона — после го адаптираме за desktop." },
        { icon: "check",         title: "ОРИЕНТИРАН КЪМ ПРОДАЖБИ",  desc: "Всяка секция има цел. CTA на правилното място. Посетителят знае какво да направи след това." },
      ].map(item => (
        <div class="flex gap-4 items-start border-l-4 border-yellow pl-4">
          <div class="shrink-0 mt-0.5"><Icon name={item.icon} size={20} /></div>
          <div>
            <div class="font-mono font-bold text-xs uppercase tracking-widest text-ink mb-1">{item.title}</div>
            <div class="text-sm text-muted leading-relaxed">{item.desc}</div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Tech stack -->
  <section class="bg-yellow border-b-2 border-ink">
    <div class="grid grid-cols-2 md:grid-cols-4 divide-x-2 divide-ink">
      {[
        { name: "Astro",       desc: "Максимална скорост" },
        { name: "Tailwind",    desc: "Отзивчив дизайн"    },
        { name: "Cloudflare",  desc: "CDN + SSL безплатно"},
        { name: "Schema.org",  desc: "Google структури"   },
      ].map(t => (
        <div class="py-5 px-6 text-center">
          <div class="font-mono font-bold text-ink text-base">{t.name}</div>
          <div class="text-xs text-ink/50 mt-0.5">{t.desc}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- 01 · За кого правим сайтове -->
  <section class="bg-cream border-b-2 border-ink">
    <div class="border-b-2 border-ink px-8 py-5">
      <span class="font-mono text-xs uppercase tracking-widest text-muted font-bold">01 · За кого правим сайтове</span>
    </div>
    <div class="px-8 py-10 max-w-3xl">
      <h2 class="font-bold text-2xl md:text-3xl tracking-tight text-ink mb-3">
        Уебсайтове за малък и среден бизнес в България
      </h2>
      <p class="text-muted leading-relaxed">
        Работим с бизнеси, при които сайтът трябва да работи — да носи клиенти, да отговаря на въпроси и да изгражда доверие. Не правим сайтове заради сайтовете.
      </p>
    </div>
    <div class="grid sm:grid-cols-2 md:grid-cols-4 divide-y-2 md:divide-y-0 md:divide-x-2 divide-ink border-t-2 border-ink">
      {industries.slice(0, 4).map(ind => (
        <div class="p-6 flex flex-col gap-3 group hover:bg-ink/5 transition-colors">
          <span class="font-mono text-xs font-bold bg-ink text-yellow px-2 py-1 self-start tracking-widest">{ind.code}</span>
          <h3 class="font-bold text-sm uppercase tracking-tight text-ink">{ind.name}</h3>
          <p class="text-xs text-muted leading-relaxed flex-1">{ind.desc}</p>
          {ind.demo && ind.href && (
            <a href={ind.href} target="_blank" class="inline-flex items-center gap-2 bg-ink text-yellow font-mono text-xs font-bold uppercase tracking-wide px-4 py-2 hover:bg-ink/80 transition-colors self-start">
              Виж демо →
            </a>
          )}
        </div>
      ))}
    </div>
    <div class="grid sm:grid-cols-2 md:grid-cols-4 divide-y-2 md:divide-y-0 md:divide-x-2 divide-ink border-t-2 border-ink">
      {industries.slice(4).map(ind => (
        <div class="p-6 flex flex-col gap-3 group hover:bg-ink/5 transition-colors">
          <span class="font-mono text-xs font-bold bg-ink text-yellow px-2 py-1 self-start tracking-widest">{ind.code}</span>
          <h3 class="font-bold text-sm uppercase tracking-tight text-ink">{ind.name}</h3>
          <p class="text-xs text-muted leading-relaxed flex-1">{ind.desc}</p>
          <a href="/contact" class="inline-flex items-center gap-2 bg-ink text-yellow font-mono text-xs font-bold uppercase tracking-wide px-4 py-2 hover:bg-ink/80 transition-colors self-start">Поискайте оферта →</a>
        </div>
      ))}
    </div>
    <div class="border-t-2 border-ink px-8 py-6 flex items-center gap-4 flex-wrap">
      <span class="text-sm text-muted">Не виждате вашия бранш?</span>
      <a href="/contact" class="font-bold text-sm text-ink underline underline-offset-4 hover:text-ink/60 transition-colors">Пишете ни — правим за всеки бизнес →</a>
    </div>
  </section>

  <!-- 02 · Как работим -->
  <section class="bg-ink border-b-2 border-ink">
    <div class="border-b-2 border-white/10 px-8 py-5">
      <span class="font-mono text-xs uppercase tracking-widest text-white/30 font-bold">02 · Как работим</span>
    </div>
    <div class="px-8 py-10 max-w-3xl">
      <h2 class="font-bold text-white leading-tight tracking-tightest mb-3" style="font-size:clamp(1.6rem,3.5vw,2.4rem)">
        От заявка до публикуван сайт — 4 стъпки
      </h2>
      <p class="text-white/40 leading-relaxed">
        Процесът е ясен и прозрачен. Знаете на всяка стъпка какво се случва, кога свършва и какво следва.
      </p>
    </div>
    <div class="grid md:grid-cols-4 divide-y-2 md:divide-y-0 md:divide-x-2 divide-white/10 border-t-2 border-white/10">
      {steps.map(step => (
        <div class="p-8 flex flex-col gap-4">
          <div class="font-mono text-4xl font-bold text-yellow/20 leading-none">{step.n}</div>
          <h3 class="font-bold text-white uppercase tracking-tight text-sm">{step.title}</h3>
          <p class="text-white/40 text-sm leading-relaxed flex-1">{step.desc}</p>
          <div class="font-mono text-xs text-yellow/60 uppercase tracking-wide">{step.detail}</div>
        </div>
      ))}
    </div>
    <div class="border-t-2 border-white/10 px-8 py-6 flex items-center gap-4 flex-wrap">
      <span class="text-white/30 text-sm">Средно 2-3 седмици от старт до публикуване</span>
      <a href="/contact" class="inline-flex items-center gap-2 bg-yellow text-ink font-bold text-sm px-6 py-3 uppercase tracking-wide hover:bg-yellow-dark transition-colors">
        Започнете сега →
      </a>
    </div>
  </section>

  <!-- 03 · WordPress срещу custom сайт -->
  <section class="bg-cream border-b-2 border-ink">
    <div class="border-b-2 border-ink px-8 py-5">
      <span class="font-mono text-xs uppercase tracking-widest text-muted font-bold">03 · WordPress или custom сайт?</span>
    </div>
    <div class="px-8 py-10 max-w-3xl">
      <h2 class="font-bold text-2xl md:text-3xl tracking-tight text-ink mb-3">
        Честен отговор на най-честия въпрос
      </h2>
      <p class="text-muted leading-relaxed">
        Много агенции продават само едното. Ние казваме кое е по-добро за вашия конкретен случай.
      </p>
    </div>
    <div class="grid md:grid-cols-3 divide-y-2 md:divide-y-0 md:divide-x-2 divide-ink border-t-2 border-ink">
      {[
        {
          tool: "Wix / Squarespace",
          verdict: "Не препоръчваме",
          verdictColor: "text-red-500",
          good: ["Бързо за старт", "Без технически знания", "Включен хостинг"],
          bad: ["Бавна скорост — SEO страда", "Трудна оптимизация за Google", "Ограничен контрол над кода", "Месечен абонамент завинаги"],
          for: "Временен сайт, тест на идея, нулев бюджет"
        },
        {
          tool: "WordPress",
          verdict: "Зависи от случая",
          verdictColor: "text-yellow-600",
          good: ["Масова платформа", "Много плъгини", "Подходящ за блогове", "Много разработчици"],
          bad: ["Нуждае се от поддръжка и обновяване", "Плъгините конфликтуват", "По-бавен от custom", "Сигурностни рискове при занемаряване"],
          for: "Голям блог с много автори, WooCommerce магазин"
        },
        {
          tool: "Custom (Astro)",
          verdict: "Препоръчваме за бизнес",
          verdictColor: "text-green-600",
          good: ["Максимална скорост (под 1с)", "Core Web Vitals зелено", "SEO от нулата в кода", "Без плъгини, без абонамент", "Безплатен хостинг на Cloudflare"],
          bad: ["Изисква разработчик за промени", "По-скъпо от DIY инструменти"],
          for: "Бизнес сайт, landing page, портфолио, кабинет"
        },
      ].map((col, i) => (
        <div class={`p-8 ${i === 2 ? 'bg-ink' : ''}`}>
          <div class="font-mono font-bold text-sm uppercase tracking-widest mb-1 text-muted">{col.tool}</div>
          <div class={`font-bold text-base mb-6 ${i === 2 ? 'text-yellow' : col.verdictColor}`}>{col.verdict}</div>
          <div class="mb-4">
            <div class={`font-mono text-xs uppercase tracking-widest mb-2 ${i === 2 ? 'text-white/30' : 'text-muted'}`}>Плюсове</div>
            <ul class="space-y-1.5">
              {col.good.map(g => (
                <li class={`text-xs flex gap-2 items-start ${i === 2 ? 'text-white/60' : 'text-muted'}`}>
                  <span class="text-green-500 shrink-0 mt-0.5">✓</span>{g}
                </li>
              ))}
            </ul>
          </div>
          <div class="mb-6">
            <div class={`font-mono text-xs uppercase tracking-widest mb-2 ${i === 2 ? 'text-white/30' : 'text-muted'}`}>Минуси</div>
            <ul class="space-y-1.5">
              {col.bad.map(b => (
                <li class={`text-xs flex gap-2 items-start ${i === 2 ? 'text-white/40' : 'text-muted/70'}`}>
                  <span class="text-red-400 shrink-0 mt-0.5">✗</span>{b}
                </li>
              ))}
            </ul>
          </div>
          <div class={`font-mono text-xs uppercase tracking-wide border-t pt-4 ${i === 2 ? 'border-white/10 text-yellow/60' : 'border-ink/10 text-muted/60'}`}>
            Подходящо за: {col.for}
          </div>
        </div>
      ))}
    </div>
    <div class="border-t-2 border-ink px-8 py-6 bg-paper">
      <p class="text-sm text-muted max-w-2xl leading-relaxed">
        <strong class="text-ink">Важно:</strong> Ако вашият случай изисква WordPress — казваме го директно и можем да препоръчаме добър разработчик. Не ни е цел да продадем custom сайт на всеки. Прочетете повече в нашата статия:&nbsp;
        <a href="/blog/wordpress-sreshtu-custom-sayt" class="font-bold text-ink underline underline-offset-4 hover:text-yellow transition-colors">WordPress срещу custom сайт →</a>
      </p>
    </div>
  </section>

  <!-- 04 · Примерни проекти -->
  <section class="bg-ink border-b-2 border-ink">
    <div class="border-b-2 border-white/10 px-8 py-5 flex items-center justify-between">
      <span class="font-mono text-xs uppercase tracking-widest text-white/30 font-bold">04 · Примерни проекти</span>
      <span class="font-mono text-xs text-white/40">Demo сайтове — виж живо</span>
    </div>
    <div class="px-8 py-8 max-w-2xl">
      <h2 class="font-bold text-white tracking-tightest mb-2" style="font-size:clamp(1.4rem,3vw,2rem)">
        Виж как изглежда реален сайт — преди да решиш
      </h2>
      <p class="text-white/35 text-sm leading-relaxed">
