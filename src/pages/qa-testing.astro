---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icons.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "QA тестване на уебсайтове и приложения",
  "provider": { "@type": "Organization", "name": "buildify.bg", "url": "https://buildify.bg" },
  "description": "7+ години QA опит. Намираме техническите грешки в сайта ти преди клиентите - ръчно тестване за малкия бизнес в България.",
  "areaServed": "Bulgaria",
  "offers": [
    { "@type": "Offer", "name": "Starter QA", "price": "75",  "priceCurrency": "EUR" },
    { "@type": "Offer", "name": "Pro QA",     "price": "250", "priceCurrency": "EUR" }
  ]
};

const packages = [
  {
    name: "Starter",
    price: "75-150€",
    for: "Малки сайтове / landing pages",
    features: [
      "Ръчно тестване на всички форми",
      "Проверка на мобилна версия",
      "Тест на 3 основни браузъра",
      "Доклад с намерените проблеми",
    ],
    featured: false,
  },
  {
    name: "Pro",
    price: "250-450€",
    for: "Корпоративни сайтове / e-commerce",
    features: [
      "Пълно функционално тестване",
      "Тест на 6+ браузъра и устройства",
      "Проверка на checkout процес",
      "Performance одит (Core Web Vitals)",
      "Доклад + препоръки за оправяне",
    ],
    featured: true,
  },
  {
    name: "Ongoing",
    price: "от 100€/мес.",
    for: "Абонаментна поддръжка",
    features: [
      "Тестване след всяка промяна",
      "Месечен health check",
      "Приоритетен отговор 24ч",
      "Мониторинг на performance",
    ],
    featured: false,
  },
];
---

<BaseLayout
  title="QA тестване на уебсайтове | 7+ години опит | buildify.bg"
  description="7+ години QA опит. Намираме техническите грешки в сайта ти преди клиентите. Тестване на уебсайтове за малкия бизнес в България. От 75€."
  schema={schema}
>
  <!-- Hero split -->
  <section class="border-b-2 border-ink grid md:grid-cols-2 min-h-[60vh]">
    <div class="bg-ink text-white px-8 md:px-14 py-16 flex flex-col justify-between">
      <span class="font-mono text-xs text-white/25 uppercase tracking-widest">buildify.bg / QA тестване</span>
      <div>
        <h1 class="font-bold text-white leading-[0.95] tracking-tightest mb-5" style="font-size:clamp(2.8rem,7vw,5rem)">
          ГРЕШКИТЕ<br/>
          <span class="bg-yellow text-ink px-2">СА НАША</span><br/>
          РАБОТА.
        </h1>
        <p class="text-white/40 text-base leading-relaxed max-w-sm">
          Намираме проблемите преди клиентите ти - на всяко устройство, всеки браузър.
        </p>
      </div>
      <a href="/kontakt" class="inline-flex items-center gap-3 bg-yellow text-ink font-bold text-sm px-7 py-4 uppercase tracking-wide hover:bg-yellow-dark transition-colors w-fit">
        Заяви QA тест →
      </a>
    </div>
    <div class="bg-cream px-8 md:px-14 py-16 flex flex-col justify-center gap-6 border-t-2 md:border-t-0 md:border-l-2 border-ink">
      {[
        { icon: "no-fee",        title: "ГУБИШ ПРОДАЖБИ",    desc: "Счупена форма = загубени клиенти, без да разбереш." },
        { icon: "mobile-broken", title: "МОБИЛЪТ Е РАЗЛИЧЕН",desc: "Изглежда добре на ноутбук, разпада се на iPhone." },
        { icon: "seo",           title: "GOOGLE НАКАЗВА",    desc: "Технически грешки = по-ниско SEO класиране." },
      ].map(item => (
        <div class="flex gap-4 items-start border-l-4 border-yellow pl-4">
          <div class="shrink-0 mt-0.5"><Icon name={item.icon} size={20} /></div>
          <div>
            <div class="font-mono font-bold text-xs uppercase tracking-widest text-ink mb-1">{item.title}</div>
            <div class="text-sm text-muted leading-relaxed">{item.desc}</div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Experience bar -->
  <section class="bg-yellow border-b-2 border-ink">
    <div class="grid grid-cols-3 divide-x-2 divide-ink">
      {[
        { val: "7+", lbl: "Години QA опит" },
        { val: "6+", lbl: "Браузъра тествани" },
        { val: "48ч", lbl: "Доклад готов" },
      ].map(s => (
        <div class="py-6 px-8 text-center">
          <div class="font-mono font-bold text-3xl text-ink">{s.val}</div>
          <div class="text-xs uppercase tracking-widest text-ink/50 mt-1 font-semibold">{s.lbl}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Packages -->
  <section class="bg-cream border-b-2 border-ink">
    <div class="border-b-2 border-ink px-8 py-5">
      <span class="font-mono text-xs uppercase tracking-widest text-muted font-bold">Пакети - 03</span>
    </div>
    <div class="grid md:grid-cols-3 divide-y-2 md:divide-y-0 md:divide-x-2 divide-ink">
      {packages.map(pkg => (
        <div class={`p-8 ${pkg.featured ? 'bg-ink' : ''}`}>
          {pkg.featured && <span class="font-mono text-xs font-bold text-yellow uppercase tracking-widest block mb-4">Препоръчан</span>}
          <h3 class={`font-bold text-2xl uppercase tracking-tight mb-1 ${pkg.featured ? 'text-white' : 'text-ink'}`}>{pkg.name}</h3>
          <div class={`font-mono font-bold text-xl mb-1 ${pkg.featured ? 'text-yellow' : 'text-ink'}`}>{pkg.price}</div>
          <div class={`text-xs uppercase tracking-wide mb-6 ${pkg.featured ? 'text-white/30' : 'text-muted'}`}>{pkg.for}</div>
          <ul class="space-y-2.5 mb-8">
            {pkg.features.map(f => (
              <li class="flex gap-3 items-start text-sm">
                <Icon name="check" size={16} />
                <span class={pkg.featured ? 'text-white/70' : 'text-muted'}>{f}</span>
              </li>
            ))}
          </ul>
          <a href="/kontakt" class={`inline-flex items-center gap-2 font-bold text-sm px-6 py-3 uppercase tracking-wide transition-colors ${pkg.featured ? 'bg-yellow text-ink hover:bg-yellow-dark' : 'bg-ink text-yellow hover:bg-ink/80'}`}>
            Заяви →
          </a>
        </div>
      ))}
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-cream border-b-2 border-ink">
    <div class="border-b-2 border-ink px-8 py-5">
      <span class="font-mono text-xs uppercase tracking-widest text-muted font-bold">Въпроси - 03</span>
    </div>
    <div class="divide-y-2 divide-ink">
      {[
        { q: "Колко отнема QA тестването?",          a: "Starter пакетът - 1-2 работни дни. Pro пакетът - до 5 дни. Зависи от обема на сайта." },
        { q: "Получавам ли доклад с резултатите?",   a: "Да - детайлен PDF доклад с всяка намерена грешка, screenshot и препоръка как да се оправи." },
        { q: "Работите ли само с WordPress?",        a: "Не. Тестваме всякакви платформи - Astro, Next.js, Shopify, WordPress, custom builds." },
      ].map(faq => (
        <details class="group px-8 py-6">
          <summary class="font-bold text-base uppercase tracking-tight text-ink cursor-pointer list-none flex justify-between items-center">
            {faq.q}
            <span class="font-mono text-yellow text-xl group-open:rotate-45 transition-transform">+</span>
          </summary>
          <p class="text-muted text-sm mt-4 leading-relaxed max-w-2xl">{faq.a}</p>
        </details>
      ))}
    </div>
  </section>
</BaseLayout>
