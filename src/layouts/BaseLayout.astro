---
import '../styles/global.css';

interface Props {
  title:       string;
  description: string;
  canonical?:  string;
  ogImage?:    string;
  schema?:     object;
}

const {
  title,
  description,
  canonical = Astro.url.href,
  ogImage   = '/og-default.svg',
  schema,
} = Astro.props;

const navLinks = [
  { href: '/websites',  label: 'Уеб дизайн' },
  { href: '/plugins',   label: 'Плъгини'    },
  { href: '/ai-bots',   label: 'AI чатбот'  },
  { href: '/blog',      label: 'Блог'       },
  { href: '/about',    label: 'За нас'     },
];

const fullTitle = title.includes('buildify') ? title : `${title} | buildify.bg`;
---
<!doctype html>
<html lang="bg">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description"        content={description} />
  <link rel="canonical"           href={canonical} />
  <meta name="robots"             content="index, follow" />
  <meta property="og:title"       content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url"         content={canonical} />
  <meta property="og:image"       content={ogImage} />
  <meta property="og:type"        content="website" />
  <meta property="og:locale"      content="bg_BG" />
  <meta property="og:site_name"   content="buildify.bg" />
  <meta name="twitter:card"       content="summary_large_image" />
  <meta name="twitter:title"      content={fullTitle} />
  <meta name="twitter:description"content={description} />
  <meta name="twitter:image"      content={ogImage} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <!-- Google Analytics 4 -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-NDHEV1Q16X"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-NDHEV1Q16X');
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "buildify.bg",
    "url": "https://buildify.bg",
    "logo": "https://buildify.bg/favicon.svg",
    "image": "https://buildify.bg/og-default.svg",
    "description": "Дигитална агенция от Бургас. Уебсайтове, AI ботове и плъгини за малкия бизнес в България.",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Бургас",
      "addressRegion": "Бургас",
      "addressCountry": "BG"
    },
    "areaServed": {
      "@type": "Country",
      "name": "Bulgaria"
    },
    "contactPoint": {
      "@type": "ContactPoint",
      "contactType": "customer service",
      "availableLanguage": "Bulgarian",
      "url": "https://buildify.bg/contact"
    },
    "sameAs": []
  }
  </script>
</head>
<body>

  <!-- ░░░ NAV - brutalist top bar ░░░ -->
  <header class="fixed top-0 left-0 right-0 z-50 bg-ink border-b-2 border-ink">
    <nav class="flex items-stretch h-14">

      <!-- Logo block -->
      <a href="/" class="flex items-center px-5 md:px-6 border-r-2 border-yellow/20 hover:bg-yellow hover:text-ink transition-colors group shrink-0">
        <span class="font-mono font-bold text-base md:text-lg text-yellow group-hover:text-ink tracking-tight">
          buildify<span class="text-white group-hover:text-ink">.</span>bg
        </span>
      </a>

      <!-- Nav links - desktop only -->
      <div class="hidden md:flex items-stretch ml-auto">
        {navLinks.map(link => (
          <a
            href={link.href}
            class="flex items-center px-5 text-sm font-semibold text-white/60 uppercase tracking-wider hover:text-yellow border-r border-white/10 transition-colors"
          >
            {link.label}
          </a>
        ))}
      </div>

      <!-- CTA + hamburger -->
      <div class="flex items-stretch ml-auto md:ml-0">
        <a
          href="/contact"
          class="flex items-center px-4 md:px-6 bg-yellow text-ink text-xs md:text-sm font-bold uppercase tracking-wider hover:bg-yellow-dark transition-colors"
        >
          <span class="hidden sm:inline">Безплатна консултация </span>→
        </a>
        <!-- Hamburger - mobile only -->
        <button
          id="mob-btn"
          class="md:hidden flex flex-col justify-center gap-1.5 px-4 border-l border-white/10"
          aria-label="Меню"
          aria-expanded="false"
          aria-controls="mob-nav"
        >
          <span class="w-5 h-0.5 bg-white block"></span>
          <span class="w-5 h-0.5 bg-white block"></span>
          <span class="w-5 h-0.5 bg-white block"></span>
        </button>
      </div>
    </nav>

    <!-- Mobile dropdown -->
    <div id="mob-nav" class="hidden md:hidden bg-ink border-t border-white/10">
      {[...navLinks, { href: '/contact', label: 'Контакти' }].map(link => (
        <a
          href={link.href}
          class="flex items-center justify-between px-6 py-4 text-sm font-semibold text-white/60 hover:text-white hover:bg-white/5 border-b border-white/10 uppercase tracking-wide transition-colors"
        >
          {link.label} <span class="text-white/40">→</span>
        </a>
      ))}
    </div>
  </header>

  <!-- PAGE CONTENT -->
  <main class="pt-14">
    <slot />
  </main>

  <!-- ░░░ FOOTER - brutalist ░░░ -->
  <footer class="bg-ink text-white border-t-2 border-yellow/20 mt-0">
    <div class="grid md:grid-cols-4 border-b border-white/10">

      <!-- Brand col -->
      <div class="p-8 md:border-r border-white/10">
        <div class="font-mono font-bold text-xl text-yellow mb-4">
          buildify<span class="text-white">.</span>bg
        </div>
        <p class="text-white/40 text-sm leading-relaxed">
          Дигитални инструменти за бизнеса.<br/>Уебсайтове, AI, QA, Плъгини.
        </p>
      </div>

      <!-- Services col -->
      <div class="p-8 md:border-r border-white/10">
        <p class="text-xs font-bold uppercase tracking-widest text-white/30 mb-5">Услуги</p>
        <ul class="space-y-3">
          {[
            ['Уеб дизайн', '/websites'],
            ['AI чатбот',  '/ai-bots'],
            ['Плъгини',    '/plugins'],
          ].map(([label, href]) => (
            <li>
              <a href={href} class="text-sm text-white/50 hover:text-yellow transition-colors flex items-center gap-2">
                <span class="text-yellow/40">→</span>{label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company col -->
      <div class="p-8 md:border-r border-white/10">
        <p class="text-xs font-bold uppercase tracking-widest text-white/30 mb-5">Компания</p>
        <ul class="space-y-3">
          {[
            ['За нас',     '/about'],
            ['Блог',       '/blog'],
            ['Контакти',   '/contact'],
          ].map(([label, href]) => (
            <li>
              <a href={href} class="text-sm text-white/50 hover:text-yellow transition-colors flex items-center gap-2">
                <span class="text-yellow/40">→</span>{label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- CTA col -->
      <div class="p-8 flex flex-col justify-between">
        <p class="text-xs font-bold uppercase tracking-widest text-white/30 mb-5">Старт</p>
        <div>
          <p class="text-white/50 text-sm mb-5">Готов за нов проект? 30 минути безплатно.</p>
          <a
            href="/contact"
            class="inline-block bg-yellow text-ink text-sm font-bold uppercase tracking-wider px-5 py-3 hover:bg-yellow-dark transition-colors"
          >
            Свържи се →
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="flex items-center justify-between px-8 py-5 text-xs text-white/45 font-mono">
      <span>© 2026 buildify.bg</span>
      <span>Astro + Tailwind + ♥</span>
    </div>
  </footer>

<script>
  const mobBtn = document.getElementById('mob-btn');
  const mobNav = document.getElementById('mob-nav');
  mobBtn?.addEventListener('click', () => {
    const expanded = mobBtn.getAttribute('aria-expanded') === 'true';
    mobBtn.setAttribute('aria-expanded', String(!expanded));
    mobNav?.classList.toggle('hidden');
  });

  // Blog view counter — fires on /blog/[slug] pages (not index)
  (async () => {
    const match = location.pathname.match(/^\/blog\/([^/]+)\/?$/);
    if (!match) return;
    const slug = match[1];
    try {
      const res = await fetch(`/api/views?slug=${slug}`, { method: 'POST' });
      const { views } = await res.json();
      document.querySelectorAll('[data-view-count]').forEach(el => {
        el.textContent = views === 1 ? '1 преглед' : `${views} прегледа`;
      });
    } catch {}
  })();
</script>
</body>
</html>
