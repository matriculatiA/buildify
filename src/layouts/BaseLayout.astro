---
import '../styles/global.css';

interface Props {
  title:       string;
  description: string;
  canonical?:  string;
  ogImage?:    string;
  schema?:     object;
}

const {
  title,
  description,
  canonical = Astro.url.href,
  ogImage   = '/og-default.svg',
  schema,
} = Astro.props;

const navLinks = [
  { href: '/websites',  label: 'Уеб дизайн' },
  { href: '/plugins',   label: 'Плъгини'    },
  { href: '/ai-bots',   label: 'AI чатбот'  },
  { href: '/blog',      label: 'Блог'       },
  { href: '/about',    label: 'За нас'     },
];

const fullTitle = title.includes('buildify') ? title : `${title} | buildify.bg`;
---
<!doctype html>
<html lang="bg">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description"        content={description} />
  <link rel="canonical"           href={canonical} />
  <meta name="robots"             content="index, follow" />
  <meta property="og:title"       content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url"         content={canonical} />
  <meta property="og:image"       content={ogImage} />
  <meta property="og:type"        content="website" />
  <meta property="og:locale"      content="bg_BG" />
  <meta property="og:site_name"   content="buildify.bg" />
  <meta name="twitter:card"       content="summary_large_image" />
  <meta name="twitter:title"      content={fullTitle} />
  <meta name="twitter:description"content={description} />
  <meta name="twitter:image"      content={ogImage} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <!-- Google Analytics 4 -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-NDHEV1Q16X"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-NDHEV1Q16X');
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "buildify.bg",
    "url": "https://buildify.bg",
    "logo": "https://buildify.bg/favicon.svg",
    "image": "https://buildify.bg/og-default.svg",
    "description": "Дигитална агенция от Бургас. Уебсайтове, AI ботове и плъгини за малкия бизнес в България.",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Бургас",
      "addressRegion": "Бургас",
      "addressCountry": "BG"
    },
    "areaServed": {
      "@type": "Country",
      "name": "Bulgaria"
    },
    "contactPoint": {
      "@type": "ContactPoint",
      "contactType": "customer service",
      "availableLanguage": "Bulgarian",
      "url": "https://buildify.bg/contact"
    },
    "sameAs": []
  }
  </script>
</head>
<body>

  <!-- ░░░ NAV - brutalist top bar ░░░ -->
  <header class="fixed top-0 left-0 right-0 z-50 bg-ink border-b-2 border-ink">
    <nav class="flex items-stretch h-14">

      <!-- Logo block -->
      <a href="/" class="flex items-center px-5 md:px-6 border-r-2 border-yellow/20 hover:bg-yellow hover:text-ink transition-colors group shrink-0">
        <span class="font-mono font-bold text-base md:text-lg text-yellow group-hover:text-ink tracking-tight">
          buildify<span class="text-white group-hover:text-ink">.</span>bg
        </span>
      </a>

      <!-- Nav links - desktop only -->
      <div class="hidden md:flex items-stretch ml-auto">
        {navLinks.map(link => (
          <a
            href={link.href}
            class="flex items-center px-5 text-sm font-semibold text-white/60 uppercase tracking-wider hover:text-yellow border-r border-white/10 transition-colors"
          >
            {link.label}
          </a>
        ))}
      </div>

      <!-- CTA + hamburger -->
      <div class="flex items-stretch ml-auto md:ml-0">
        <a
          href="/contact"
          class="flex items-center px-4 md:px-6 bg-yellow text-ink text-xs md:text-sm font-bold uppercase tracking-wider hover:bg-yellow-dark transition-colors"
        >
          <span class="hidden sm:inline">Безплатна консултация </span>→
        </a>
        <!-- Hamburger - mobile only -->
        <button
          id="mob-btn"
          class="md:hidden flex flex-col justify-center gap-1.5 px-4 border-l border-white/10"
          aria-label="Меню"
          aria-expanded="false"
          aria-controls="mob-nav"
        >
          <span class="w-5 h-0.5 bg-white block"></span>
          <span class="w-5 h-0.5 bg-white block"></span>
          <span class="w-5 h-0.5 bg-white block"></span>
        </button>
      </div>
    </nav>

    <!-- Mobile dropdown -->
    <div id="mob-nav" class="hidden md:hidden bg-ink border-t border-white/10">
      {[...navLinks, { href: '/contact', label: 'Контакти' }].map(link => (
        <a
          href={link.href}
          class="flex items-center justify-between px-6 py-4 text-sm font-semibold text-white/60 hover:text-white hover:bg-white/5 border-b border-white/10 uppercase tracking-wide transition-colors"
        >
          {link.label} <span class="text-white/40">→</span>
        </a>
      ))}
    </div>
  </header>

  <!-- PAGE CONTENT -->
  <main class="pt-14">
    <slot />
  </main>

  <!-- ░░░ FOOTER - brutalist ░░░ -->
  <footer class="bg-ink text-white border-t-2 border-yellow/20 mt-0">
    <div class="grid md:grid-cols-4 border-b border-white/10">

      <!-- Brand col -->
      <div class="p-8 md:border-r border-white/10">
        <div class="font-mono font-bold text-xl text-yellow mb-4">
          buildify<span class="text-white">.</span>bg
        </div>
        <p class="text-white/40 text-sm leading-relaxed">
          Дигитални инструменти за бизнеса.<br/>Уебсайтове, AI, QA, Плъгини.
        </p>
      </div>

      <!-- Services col -->
      <div class="p-8 md:border-r border-white/10">
        <p class="text-xs font-bold uppercase tracking-widest text-white/30 mb-5">Услуги</p>
        <ul class="space-y-3">
          {[
            ['Уеб дизайн', '/websites'],
            ['AI чатбот',  '/ai-bots'],
            ['Плъгини',    '/plugins'],
          ].map(([label, href]) => (
            <li>
              <a href={href} class="text-sm text-white/50 hover:text-yellow transition-colors flex items-center gap-2">
                <span class="text-yellow/40">→</span>{label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company col -->
      <div class="p-8 md:border-r border-white/10">
        <p class="text-xs font-bold uppercase tracking-widest text-white/30 mb-5">Компания</p>
        <ul class="space-y-3">
          {[
            ['За нас',     '/about'],
            ['Блог',       '/blog'],
            ['Контакти',   '/contact'],
          ].map(([label, href]) => (
            <li>
              <a href={href} class="text-sm text-white/50 hover:text-yellow transition-colors flex items-center gap-2">
                <span class="text-yellow/40">→</span>{label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- CTA col -->
      <div class="p-8 flex flex-col justify-between">
        <p class="text-xs font-bold uppercase tracking-widest text-white/30 mb-5">Старт</p>
        <div>
          <p class="text-white/50 text-sm mb-5">Готов за нов проект? 30 минути безплатно.</p>
          <a
            href="/contact"
            class="inline-block bg-yellow text-ink text-sm font-bold uppercase tracking-wider px-5 py-3 hover:bg-yellow-dark transition-colors"
          >
            Свържи се →
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="flex items-center justify-between px-8 py-5 text-xs text-white/45 font-mono">
      <span>© 2026 buildify.bg</span>
      <span>Astro + Tailwind + ♥</span>
    </div>
  </footer>

<script>
  const mobBtn = document.getElementById('mob-btn');
  const mobNav = document.getElementById('mob-nav');
  mobBtn?.addEventListener('click', () => {
    const expanded = mobBtn.getAttribute('aria-expanded') === 'true';
    mobBtn.setAttribute('aria-expanded', String(!expanded));
    mobNav?.classList.toggle('hidden');
  });
</script>

<!-- ░░░ CHAT WIDGET ░░░ -->
<style>
  #cw { position:fixed; bottom:24px; right:24px; z-index:9999; font-family:'Space Grotesk',sans-serif; }

  /* Toggle button */
  #cw-btn {
    width:52px; height:52px; background:#111; border:2px solid #111;
    display:flex; align-items:center; justify-content:center;
    cursor:pointer; position:relative; transition:background .15s;
  }
  #cw-btn:hover { background:#222; }
  #cw-btn svg { width:22px; height:22px; fill:none; stroke:#f5e642; stroke-width:2; stroke-linecap:round; }
  #cw-badge {
    display:none; position:absolute; top:-5px; right:-5px;
    width:14px; height:14px; background:#f5e642; border:2px solid #111; border-radius:50%;
  }
  #cw-badge.visible { display:block; }

  /* Notification bar */
  #cw-notif {
    display:none; position:absolute; bottom:64px; right:0;
    background:#111; border:2px solid #111; padding:10px 14px;
    white-space:nowrap; cursor:pointer;
    font-size:13px; font-weight:600; color:#fff;
    animation: cwSlide .2s ease;
  }
  #cw-notif span { color:#f5e642; margin-left:6px; }
  #cw-notif-x { color:rgba(255,255,255,.35); margin-left:10px; cursor:pointer; font-size:11px; }
  #cw-notif-x:hover { color:#fff; }

  /* Panel */
  #cw-panel {
    display:none; position:absolute; bottom:64px; right:0;
    width:320px; border:2px solid #111; background:#fff;
    flex-direction:column; overflow:hidden;
    animation: cwSlide .15s ease;
  }
  #cw-panel.open { display:flex; }

  @keyframes cwSlide {
    from { opacity:0; transform:translateY(8px); }
    to   { opacity:1; transform:translateY(0); }
  }

  /* Header */
  #cw-head {
    background:#111; padding:12px 16px;
    display:flex; align-items:center; justify-content:space-between; flex-shrink:0;
  }
  #cw-head-brand { color:#f5e642; font-family:'Space Mono',monospace; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.08em; }
  #cw-head-sub   { color:rgba(255,255,255,.35); font-size:11px; margin-top:2px; }
  #cw-dot { width:8px; height:8px; background:#22c55e; border-radius:50%; flex-shrink:0; }

  /* Messages */
  #cw-msgs {
    flex:1; overflow-y:auto; padding:14px; display:flex;
    flex-direction:column; gap:10px; background:#f0ede6;
    min-height:220px; max-height:300px;
  }
  .cw-msg { max-width:82%; font-size:13px; line-height:1.5; }
  .cw-msg-bot { align-self:flex-start; background:#fff; border:1.5px solid #ddd; padding:8px 12px; color:#111; }
  .cw-msg-user { align-self:flex-end; background:#111; padding:8px 12px; color:#f5e642; font-weight:600; }
  .cw-typing { align-self:flex-start; background:#fff; border:1.5px solid #ddd; padding:8px 14px; color:#999; font-size:18px; letter-spacing:2px; }

  /* Email bar */
  #cw-email-bar {
    display:none; padding:8px 10px; border-top:2px solid #111;
    background:#fffbea; gap:6px; align-items:center; flex-shrink:0;
  }
  #cw-email-bar.visible { display:flex; }
  #cw-email-bar label { font-family:'Space Mono',monospace; font-size:9px; font-weight:700; text-transform:uppercase; letter-spacing:.06em; color:#777; white-space:nowrap; }
  #cw-email-inp {
    flex:1; border:1.5px solid #ccc; padding:6px 8px;
    font-size:13px; outline:none; font-family:'Space Grotesk',sans-serif; min-width:0;
  }
  #cw-email-inp:focus { border-color:#111; }
  #cw-email-ok {
    background:#f5e642; border:none; border-left:none; padding:6px 12px;
    font-family:'Space Mono',monospace; font-size:10px; font-weight:700;
    cursor:pointer; flex-shrink:0; border:1.5px solid #111;
  }
  #cw-email-ok:hover { background:#d4c30a; }

  /* Input row */
  #cw-inp-row { display:flex; border-top:2px solid #111; flex-shrink:0; }
  #cw-inp {
    flex:1; border:none; padding:11px 14px; font-size:14px; outline:none;
    font-family:'Space Grotesk',sans-serif; color:#111; background:#fff;
  }
  #cw-send {
    background:#f5e642; border:none; border-left:2px solid #111;
    padding:11px 16px; cursor:pointer; font-family:'Space Mono',monospace;
    font-size:14px; font-weight:700; flex-shrink:0; transition:background .1s;
  }
  #cw-send:hover { background:#d4c30a; }
  #cw-send:disabled { background:#e8e4dc; cursor:not-allowed; }

  @media (max-width: 400px) {
    #cw-panel { width:calc(100vw - 32px); right:0; }
  }
</style>

<div id="cw">
  <!-- Notification bar -->
  <div id="cw-notif">
    Здравейте! Мога ли да помогна? <span>→</span>
    <span id="cw-notif-x">✕</span>
  </div>

  <!-- Chat panel -->
  <div id="cw-panel" role="dialog" aria-label="Чат асистент">
    <div id="cw-head">
      <div>
        <div id="cw-head-brand">buildify.bg</div>
        <div id="cw-head-sub">Асистент</div>
      </div>
      <div id="cw-dot"></div>
    </div>
    <div id="cw-msgs"></div>
    <div id="cw-email-bar">
      <label>Имейл</label>
      <input id="cw-email-inp" type="email" placeholder="твоя@имейл.bg" />
      <button id="cw-email-ok">OK</button>
    </div>
    <div id="cw-inp-row">
      <input id="cw-inp" type="text" placeholder="Напиши съобщение..." autocomplete="off" maxlength="500" />
      <button id="cw-send" aria-label="Изпрати">→</button>
    </div>
  </div>

  <!-- Toggle button -->
  <button id="cw-btn" aria-label="Отвори чат">
    <!-- Chat icon -->
    <svg id="cw-ico-open" viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
    <!-- Close icon -->
    <svg id="cw-ico-close" style="display:none" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    <span id="cw-badge"></span>
  </button>
</div>

<script>
(function () {
  const panel   = document.getElementById('cw-panel');
  const btn     = document.getElementById('cw-btn');
  const icoOpen = document.getElementById('cw-ico-open');
  const icoClose= document.getElementById('cw-ico-close');
  const badge   = document.getElementById('cw-badge');
  const notif   = document.getElementById('cw-notif');
  const notifX  = document.getElementById('cw-notif-x');
  const msgsEl  = document.getElementById('cw-msgs');
  const inp     = document.getElementById('cw-inp');
  const sendBtn = document.getElementById('cw-send');
  const emailBar= document.getElementById('cw-email-bar');
  const emailInp= document.getElementById('cw-email-inp');
  const emailOk = document.getElementById('cw-email-ok');

  let isOpen       = false;
  let history      = [];
  let leadEmail    = null;
  let leadSent     = false;
  let exchanges    = 0;
  let proactiveDone= false;

  // ── helpers ──────────────────────────────────────────
  function addMsg(role, text) {
    const div = document.createElement('div');
    div.className = 'cw-msg ' + (role === 'bot' ? 'cw-msg-bot' : 'cw-msg-user');
    // linkify /path references
    div.innerHTML = text.replace(/\/([\w-]+)/g, (m, p) =>
      `<a href="${m}" style="color:inherit;text-decoration:underline">${m}</a>`
    );
    msgsEl.appendChild(div);
    msgsEl.scrollTop = msgsEl.scrollHeight;
    return div;
  }

  function showTyping() {
    const d = document.createElement('div');
    d.className = 'cw-typing'; d.id = 'cw-typing'; d.textContent = '···';
    msgsEl.appendChild(d);
    msgsEl.scrollTop = msgsEl.scrollHeight;
  }
  function hideTyping() {
    document.getElementById('cw-typing')?.remove();
  }

  function openPanel() {
    isOpen = true;
    panel.classList.add('open');
    icoOpen.style.display  = 'none';
    icoClose.style.display = '';
    badge.classList.remove('visible');
    notif.style.display = 'none';
    inp.focus();
    if (history.length === 0) botGreet();
  }

  function closePanel() {
    isOpen = false;
    panel.classList.remove('open');
    icoOpen.style.display  = '';
    icoClose.style.display = 'none';
  }

  function botGreet() {
    const page = window.location.pathname;
    let greeting = 'Здравейте! Как мога да помогна днес?';
    if (page.includes('websites'))  greeting = 'Здравейте! Разглеждате уебсайтовете ни. Имате ли въпроси за цени или срокове?';
    if (page.includes('plugins'))   greeting = 'Здравейте! Интересувате ли се от конкретен плъгин или функционалност?';
    if (page.includes('ai-bots'))   greeting = 'Здравейте! Обмисляте AI бот за бизнеса си? Мога да помогна да прецените дали си струва.';
    if (page.includes('contact'))   greeting = 'Здравейте! Виждам, че сте на страницата за контакти. Мога ли да отговоря на въпроси преди да изпратите форма?';
    if (page.includes('blog'))      greeting = 'Здравейте! Търсите ли информация по конкретна тема?';
    addMsg('bot', greeting);
  }

  // ── API call ──────────────────────────────────────────
  async function sendMessage(text) {
    if (!text.trim()) return;
    inp.value = '';
    sendBtn.disabled = true;
    addMsg('user', text);
    history.push({ role: 'user', content: text });

    showTyping();

    try {
      const res = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          messages: history,
          pageUrl: window.location.pathname,
          leadEmail: leadSent ? null : leadEmail,
        }),
      });
      const data = await res.json();
      hideTyping();
      const reply = data.reply || 'Извини, нещо се обърка. Пиши ни на hello@buildify.bg';
      history.push({ role: 'assistant', content: reply });
      addMsg('bot', reply);
      exchanges++;

      if (leadEmail && !leadSent) leadSent = true;

      // Show email bar after 2 exchanges if no email yet
      if (exchanges >= 2 && !leadEmail) {
        emailBar.classList.add('visible');
        emailInp.focus();
      }
    } catch {
      hideTyping();
      addMsg('bot', 'Технически проблем. Пиши ни на hello@buildify.bg');
    }

    sendBtn.disabled = false;
    inp.focus();
  }

  // ── email submit ──────────────────────────────────────
  emailOk.addEventListener('click', () => {
    const val = emailInp.value.trim();
    if (!val || !val.includes('@')) { emailInp.focus(); return; }
    leadEmail = val;
    leadSent  = false;
    emailBar.classList.remove('visible');
    addMsg('bot', 'Благодаря! Ще се свържем с вас при нужда. Продължете с въпросите си.');
    // Trigger API to send the lead
    fetch('/api/chat', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        messages: history,
        pageUrl: window.location.pathname,
        leadEmail: leadEmail,
      }),
    }).then(() => { leadSent = true; }).catch(() => {});
  });

  emailInp.addEventListener('keydown', e => { if (e.key === 'Enter') emailOk.click(); });

  // ── toggle ────────────────────────────────────────────
  btn.addEventListener('click', () => isOpen ? closePanel() : openPanel());

  // ── send ──────────────────────────────────────────────
  sendBtn.addEventListener('click', () => sendMessage(inp.value));
  inp.addEventListener('keydown', e => { if (e.key === 'Enter') sendMessage(inp.value); });

  // ── notification bar after 60s ────────────────────────
  notif.addEventListener('click', (e) => {
    if (e.target === notifX) { notif.style.display = 'none'; return; }
    notif.style.display = 'none';
    openPanel();
  });
  notifX.addEventListener('click', (e) => {
    e.stopPropagation();
    notif.style.display = 'none';
  });

  setTimeout(() => {
    if (!isOpen && !proactiveDone) {
      proactiveDone = true;
      badge.classList.add('visible');
      notif.style.display = 'block';
    }
  }, 60000);

})();
</script>
</body>
</html>
